@page
@model Users.IndexModel

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="bi bi-people me-2 text-primary"></i>Users Management
    </h1>
    <button class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Add User
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-light">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <input type="search"
                       name="Search"
                       value="@Model.Search"
                       class="form-control form-control-sm"
                       placeholder="Search by name, email or username…"
                       hx-get="/Users?handler=Table"
                       hx-trigger="keyup changed delay:300ms, search"
                       hx-target="#users-table-container"
                       hx-swap="outerHTML"
                       hx-push-url="true"
                       hx-include="[name='Search'],[name='SortBy'],[name='Desc'],[name='PageSize']" />
            </div>
        </div>
    </div>

    <div id="users-table-container">
        <partial name="_UserTableRows" model="Model" />
    </div>
</div>
