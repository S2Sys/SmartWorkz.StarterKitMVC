@page
@model Permissions.IndexModel

@{
    ViewData["Title"] = "Permissions";
}

<div class="row mb-4">
    <div class="col-md-12">
        <h1 class="h3" style="color: #1f2937;">
            <i class="bi bi-shield-lock me-2" style="color: #10b981;"></i>Permissions Management
        </h1>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Permissions List</h5>
                    <button class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>Add Permission
                    </button>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted mb-0">Permission management interface coming soon.</p>
            </div>
        </div>
    </div>
</div>
