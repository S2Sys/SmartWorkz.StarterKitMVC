@model Products.IndexModel

<table class="table table-sm table-hover mb-0">
    <thead class="table-light">
        <tr>
            <th>SKU</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Products.Any())
        {
            @foreach (var product in Model.Products)
            {
                <tr>
                    <td><code>@product.SKU</code></td>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name</td>
                    <td>$@product.Price.ToString("0.00")</td>
                    <td>
                        <span class="@(product.Stock > 0 ? "badge bg-success" : "badge bg-danger")">
                            @product.Stock
                        </span>
                    </td>
                    <td>
                        <span class="badge @(product.IsActive ? "bg-primary" : "bg-secondary")">
                            @product.Status
                        </span>
                    </td>
                    <td>
                        <a href="@Url.Page("./Edit", new { id = product.ProductId })" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn btn-sm btn-outline-danger"
                                hx-delete="/Products/@product.ProductId"
                                hx-confirm="Are you sure?"
                                hx-target="#products-table-container"
                                hx-swap="outerHTML">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">
                    No products found
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Pagination.TotalPages > 1)
{
    <nav class="d-flex justify-content-between align-items-center p-3 border-top">
        <small class="text-muted">
            Showing @Model.Pagination.FirstItem to @Model.Pagination.LastItem of @Model.Pagination.TotalItems
        </small>

        <ul class="pagination pagination-sm mb-0">
            @if (Model.Pagination.HasPrev)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Page("./Index", new { page = Model.Pagination.CurrentPage - 1 })">Previous</a>
                </li>
            }

            @foreach (var pageNum in Model.Pagination.PageWindow())
            {
                @if (pageNum == -1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                else if (pageNum == Model.Pagination.CurrentPage)
                {
                    <li class="page-item active"><span class="page-link">@pageNum</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Page("./Index", new { page = pageNum })">@pageNum</a>
                    </li>
                }
            }

            @if (Model.Pagination.HasNext)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Page("./Index", new { page = Model.Pagination.CurrentPage + 1 })">Next</a>
                </li>
            }
        </ul>
    </nav>
}
