@page "{id:int}"
@model EditModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0">
                    <i class="bi bi-pencil-circle me-2 text-primary"></i>Edit Product
                </h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.SKU" class="form-label"></label>
                                <input asp-for="Input.SKU" class="form-control">
                                <span asp-validation-for="Input.SKU" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.Name" class="form-label"></label>
                                <input asp-for="Input.Name" class="form-control">
                                <span asp-validation-for="Input.Name" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Slug" class="form-label"></label>
                        <input asp-for="Input.Slug" class="form-control">
                        <span asp-validation-for="Input.Slug" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.CategoryId" class="form-label"></label>
                                <select asp-for="Input.CategoryId" class="form-select" asp-items="@(new SelectList(Model.Categories, "CategoryId", "Name"))"></select>
                                <span asp-validation-for="Input.CategoryId" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.Price" class="form-label"></label>
                                <input asp-for="Input.Price" type="number" step="0.01" class="form-control">
                                <span asp-validation-for="Input.Price" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.CostPrice" class="form-label"></label>
                                <input asp-for="Input.CostPrice" type="number" step="0.01" class="form-control">
                                <span asp-validation-for="Input.CostPrice" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Input.Stock" class="form-label"></label>
                                <input asp-for="Input.Stock" type="number" class="form-control">
                                <span asp-validation-for="Input.Stock" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="Input.IsFeatured" class="form-check-input">
                            <label asp-for="Input.IsFeatured" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Update Product
                        </button>
                        <a href="@Url.Page("./Index")" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
