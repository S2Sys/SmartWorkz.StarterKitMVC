@page
@model Products.IndexModel

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="bi bi-box me-2 text-primary"></i>Products Management
    </h1>
    <a href="@Url.Page("./Create")" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Add Product
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-light">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <input type="search"
                       name="Search"
                       value="@Model.Search"
                       class="form-control form-control-sm"
                       placeholder="Search by name, SKU…"
                       hx-get="/Products?handler=Table"
                       hx-trigger="keyup changed delay:300ms, search"
                       hx-target="#products-table-container"
                       hx-swap="outerHTML"
                       hx-push-url="true"
                       hx-include="[name='Search'],[name='SortBy'],[name='Desc'],[name='PageSize']" />
            </div>
        </div>
    </div>

    <div id="products-table-container">
        <partial name="_ProductTableRows" model="Model" />
    </div>
</div>
