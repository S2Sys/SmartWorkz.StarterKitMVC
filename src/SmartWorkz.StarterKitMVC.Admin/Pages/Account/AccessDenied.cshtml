@page
@model AccessDeniedModel

@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartWorkz Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
        }
        .card-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 420px;
            padding: 40px;
            text-align: center;
        }
        .icon-circle {
            width: 80px; height: 80px;
            background: rgba(239,68,68,0.1);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            font-size: 36px; color: #ef4444;
        }
        h1 { font-size: 22px; font-weight: 700; color: #1e293b; margin-bottom: 8px; }
        p  { color: #6b7280; font-size: 14px; margin-bottom: 0; }
        .btn-home {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            border: none; border-radius: 8px;
            padding: 10px 24px; font-weight: 600; color: white;
            text-decoration: none; display: inline-block; margin-top: 24px;
        }
        .btn-home:hover { opacity: 0.9; color: white; }
        .btn-logout {
            border: 1px solid #e5e7eb; border-radius: 8px;
            padding: 10px 24px; font-weight: 500; color: #6b7280;
            background: white; text-decoration: none;
            display: inline-block; margin-top: 12px;
        }
        .btn-logout:hover { background: #f9fafb; color: #374151; }
    </style>
</head>
<body>
    <div class="card-container">
        <div class="icon-circle">
            <i class="bi bi-shield-x"></i>
        </div>
        <h1>Access Denied</h1>
        <p>You don't have permission to view this page.<br>Admin role is required.</p>

        <div class="d-flex flex-column gap-2 mt-3">
            <a asp-page="/Dashboard/Index" class="btn-home">
                <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
            </a>
            <a asp-page="/Account/Profile" class="btn-logout" style="font-size:13px;">
                <i class="bi bi-key me-1"></i>View my auth state
            </a>
            <form method="post" asp-page="/Account/Logout" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout w-100">
                    <i class="bi bi-box-arrow-right me-1"></i>Sign out and try different account
                </button>
            </form>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-3 p-2 rounded" style="background:#f8fafc; font-size:12px; color:#9ca3af;">
                Signed in as <strong>@User.Identity.Name</strong>
                &mdash; roles: <strong>@string.Join(", ", User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value))</strong>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
