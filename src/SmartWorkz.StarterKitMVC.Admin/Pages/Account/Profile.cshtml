@page
@model SmartWorkz.StarterKitMVC.Admin.Pages.Account.ProfileModel

@{
    ViewData["Title"] = "Auth Diagnostic";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">Auth Diagnostic</h1>
        <p class="text-muted small mb-0">Current session identity, roles and claims</p>
    </div>
    <span class="badge @(Model.IsAuthenticated ? "bg-success" : "bg-danger") fs-6 px-3 py-2">
        <i class="bi bi-@(Model.IsAuthenticated ? "check-circle" : "x-circle") me-1"></i>
        @(Model.IsAuthenticated ? "Authenticated" : "Not Authenticated")
    </span>
</div>

@if (!Model.IsAuthenticated)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No authenticated session. <a asp-page="/Account/Login" class="alert-link">Sign in</a> to see your auth state.
    </div>
}
else
{
    <!-- Identity Card -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom fw-semibold">
                    <i class="bi bi-person-badge me-2 text-primary"></i>Identity
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr><td class="text-muted" style="width:130px;">Auth Scheme</td><td><span class="badge bg-primary">@Model.AuthScheme</span></td></tr>
                            <tr><td class="text-muted">User ID</td><td><code class="small">@Model.UserId</code></td></tr>
                            <tr><td class="text-muted">Email</td><td>@Model.Email</td></tr>
                            <tr><td class="text-muted">Name</td><td>@Model.DisplayName</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Roles -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom fw-semibold">
                    <i class="bi bi-person-fill-gear me-2 text-success"></i>Roles
                    <span class="badge bg-success ms-1">@Model.Roles.Count</span>
                </div>
                <div class="card-body">
                    @if (Model.Roles.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var role in Model.Roles)
                            {
                                <span class="badge bg-success fs-6 px-3 py-2">
                                    <i class="bi bi-person-fill-gear me-1"></i>@role
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">No roles in cookie claims.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Permissions -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-shield-check me-2 text-warning"></i>Permissions
            <span class="badge bg-warning text-dark ms-1">@Model.Permissions.Count</span>
        </div>
        <div class="card-body">
            @if (Model.Permissions.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var perm in Model.Permissions)
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">@perm</span>
                    }
                </div>
            }
            else
            {
                <p class="text-muted small mb-0">
                    No permission claims in cookie.
                    <span class="text-danger">Check that Login sets permission claims and PermissionMiddleware is running.</span>
                </p>
            }
        </div>
    </div>

    <!-- All Claims -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-key me-2 text-secondary"></i>All Cookie Claims
            <span class="badge bg-secondary ms-1">@Model.AllClaims.Count</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:220px;">Claim Type</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (type, value) in Model.AllClaims)
                    {
                        <tr>
                            <td><code class="text-muted small">@type</code></td>
                            <td class="small">@value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
