@{
    var year = DateTime.UtcNow.Year;
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString()?.ToLower() ?? "";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SmartWorkz Admin Portal" />
    <title>@ViewData["Title"] - Admin Portal</title>

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5.3.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/admin.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex min-vh-100">
        <!-- Sidebar -->
        <nav class="sidebar bg-dark text-light p-3" style="width: 250px; position: fixed; height: 100vh; overflow-y: auto; left: 0; top: 0;">
            <div class="mb-4">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-page="/Dashboard/Index" style="color: #6366f1;">
                    <i class="bi bi-rocket-takeoff me-2" style="color: #f59e0b;"></i>
                    <span>SmartWorkz</span>
                </a>
            </div>

            <!-- Dashboard -->
            <div class="nav flex-column gap-1">
                <a class="nav-link @(currentPage.Contains("/dashboard") ? "active" : "")" asp-page="/Dashboard/Index" style="color: #cbd5e1;">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
            </div>

            <hr style="border-color: rgba(255,255,255,0.1); margin: 0.75rem 0;">

            <!-- Administration Section -->
            <div class="nav-group">
                <button class="nav-group-toggle btn btn-link text-start w-100" type="button" data-bs-toggle="collapse" data-bs-target="#adminMenu" style="color: #a1a5b4; padding: 0.5rem 0;">
                    <i class="bi bi-shield me-2"></i>Administration
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.85rem;"></i>
                </button>
                <div class="collapse show" id="adminMenu">
                    <ul class="nav flex-column gap-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/users") ? "active" : "")" asp-page="/Users/Index" style="color: #cbd5e1;">
                                <i class="bi bi-people me-2"></i>Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/tenants") ? "active" : "")" asp-page="/Tenants/Index" style="color: #cbd5e1;">
                                <i class="bi bi-building me-2"></i>Tenants
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/permissions") ? "active" : "")" asp-page="/Permissions/Index" style="color: #cbd5e1;">
                                <i class="bi bi-shield-lock me-2"></i>Permissions
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Content Section -->
            <div class="nav-group">
                <button class="nav-group-toggle btn btn-link text-start w-100" type="button" data-bs-toggle="collapse" data-bs-target="#contentMenu" style="color: #a1a5b4; padding: 0.5rem 0;">
                    <i class="bi bi-file-text me-2"></i>Content
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.85rem;"></i>
                </button>
                <div class="collapse show" id="contentMenu">
                    <ul class="nav flex-column gap-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/products") ? "active" : "")" asp-page="/Products/Index" style="color: #cbd5e1;">
                                <i class="bi bi-box me-2"></i>Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/emailtemplates") ? "active" : "")" asp-page="/EmailTemplates/Index" style="color: #cbd5e1;">
                                <i class="bi bi-envelope me-2"></i>Email Templates
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Data Management Section -->
            <div class="nav-group">
                <button class="nav-group-toggle btn btn-link text-start w-100" type="button" data-bs-toggle="collapse" data-bs-target="#dataMenu" style="color: #a1a5b4; padding: 0.5rem 0;">
                    <i class="bi bi-database me-2"></i>Data Management
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.85rem;"></i>
                </button>
                <div class="collapse show" id="dataMenu">
                    <ul class="nav flex-column gap-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/lookups") ? "active" : "")" asp-page="/Lookups/Index" style="color: #cbd5e1;">
                                <i class="bi bi-list-check me-2"></i>Lookups
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/resources") ? "active" : "")" asp-page="/Resources/Languages" style="color: #cbd5e1;">
                                <i class="bi bi-translate me-2"></i>Resources
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- System Section -->
            <div class="nav-group">
                <button class="nav-group-toggle btn btn-link text-start w-100" type="button" data-bs-toggle="collapse" data-bs-target="#systemMenu" style="color: #a1a5b4; padding: 0.5rem 0;">
                    <i class="bi bi-gear me-2"></i>System
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.85rem;"></i>
                </button>
                <div class="collapse show" id="systemMenu">
                    <ul class="nav flex-column gap-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/settings") ? "active" : "")" asp-page="/Settings/Index" style="color: #cbd5e1;">
                                <i class="bi bi-sliders me-2"></i>Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/calendar") ? "active" : "")" asp-page="/Calendar/Index" style="color: #cbd5e1;">
                                <i class="bi bi-calendar-event me-2"></i>Calendar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.Contains("/theme") ? "active" : "")" asp-page="/Theme/Index" style="color: #cbd5e1;">
                                <i class="bi bi-palette me-2"></i>Theme
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <hr style="border-color: rgba(255,255,255,0.1); margin-top: 1rem;">

            <ul class="nav flex-column gap-2">
                <li class="nav-item">
                    <a class="nav-link @(currentPage.Contains("/account/profile") ? "active" : "")" asp-page="/Account/Profile" style="color: #cbd5e1;">
                        <i class="bi bi-key me-2"></i>Auth Diagnostic
                    </a>
                </li>
                <li class="nav-item">
                    <form method="post" asp-page="/Account/Logout" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link btn btn-link p-0 border-0" style="color: #cbd5e1; width: 100%; text-align: left;">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </li>
            </ul>
        </nav>

        <!-- Main Content -->
        <div style="margin-left: 250px; flex-grow: 1;">
            <!-- Top Bar -->
            <nav class="navbar navbar-light bg-light border-bottom" style="position: sticky; top: 0; z-index: 100;">
                <div class="container-fluid">
                    <span class="navbar-text text-muted">Admin Portal</span>
                    <div>
                        <small class="text-muted">@User.Identity?.Name</small>
                    </div>
                </div>
            </nav>

            <!-- Page Content -->
            <main class="p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Toast Container -->
    <partial name="_ToastContainer" />

    <!-- Loading Overlay -->
    <partial name="_LoadingOverlay" />

    <!-- Confirm Modal -->
    <partial name="_ConfirmModal" />

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@2.0.3" crossorigin="anonymous"></script>
    <script>
        document.body.addEventListener('htmx:configRequest', evt => {
            evt.detail.headers['RequestVerificationToken'] =
                document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        });
    </script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
.sidebar .nav-link {
    transition: all 0.2s ease;
    font-size: 0.95rem;
}

.sidebar .nav-link:hover {
    background: rgba(99, 102, 241, 0.1);
    color: #6366f1 !important;
}

.sidebar .nav-link.active {
    background: rgba(99, 102, 241, 0.2);
    color: #6366f1 !important;
    border-left: 3px solid #6366f1;
    padding-left: calc(0.75rem - 3px);
}

.nav-group-toggle {
    font-size: 0.95rem;
    padding: 0.5rem !important;
    border: none;
    transition: all 0.2s ease;
    margin-bottom: 0.5rem;
}

.nav-group-toggle:hover {
    background: rgba(99, 102, 241, 0.1) !important;
    color: #6366f1 !important;
}

.nav-group-toggle i:last-child {
    transition: transform 0.3s ease;
}

.nav-group-toggle[aria-expanded="true"] i:last-child {
    transform: rotate(180deg);
}

.nav-group-toggle[aria-expanded="false"] i:last-child {
    transform: rotate(0deg);
}

.nav-group {
    margin-bottom: 0.5rem;
}

.nav-group .nav-link {
    font-size: 0.9rem;
    padding: 0.4rem 0.75rem !important;
}
</style>
