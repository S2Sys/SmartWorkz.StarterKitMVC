<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SmartWorkz.Mobile.Components.AlertDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Grid
        x:Name="DialogContainer"
        BackgroundColor="#80000000"
        ColumnDefinitions="*"
        RowDefinitions="*"
        IsVisible="{Binding IsOpen, Source={RelativeSource AncestorType={x:Type ContentView}}}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand, Source={RelativeSource AncestorType={x:Type ContentView}}}" />
        </Grid.GestureRecognizers>
        <Border
            Grid.Row="0"
            Margin="20"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 12"
            Padding="20">
            <VerticalStackLayout Spacing="16">
                <Label
                    x:Name="TitleLabel"
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                    TextColor="#333333" />
                <Label
                    x:Name="MessageLabel"
                    FontSize="14"
                    Text="{Binding Message, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                    TextColor="#666666" />
                <HorizontalStackLayout Spacing="8">
                    <Button
                        x:Name="CancelButton"
                        BackgroundColor="#E8E8E8"
                        CornerRadius="6"
                        FontSize="14"
                        Text="{Binding CancelText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                        TextColor="Black"
                        WidthRequest="120" />
                    <Button
                        x:Name="ConfirmButton"
                        BackgroundColor="#007AFF"
                        CornerRadius="6"
                        FontSize="14"
                        Text="{Binding ConfirmText, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                        TextColor="White"
                        WidthRequest="120" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
