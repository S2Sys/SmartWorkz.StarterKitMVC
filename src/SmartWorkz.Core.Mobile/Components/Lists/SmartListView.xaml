<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SmartWorkz.Mobile.Components.SmartListView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <CollectionView
        x:Name="CollectionViewControl"
        ItemsSource="{Binding ItemsSource, Source={RelativeSource AncestorType={x:Type ContentView}}}"
        SelectionMode="Single">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout
                ItemSpacing="8"
                Orientation="Vertical" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border
                    Margin="0,8"
                    StrokeShape="RoundRectangle 8"
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    Shadow="{Shadow Offset='0,2', Radius='4', Opacity='0.15', Color=Black}">
                    <Label
                        FontSize="14"
                        Text="{Binding .}"
                        TextColor="#333333" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentView>
