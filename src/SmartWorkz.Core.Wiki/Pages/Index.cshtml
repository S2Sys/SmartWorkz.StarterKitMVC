@page
@model IndexModel
@{
    ViewData["Title"] = "SmartWorkz Core Documentation";
}

<div style="padding: 2.5rem 2rem 1.5rem; border-bottom: 1px solid var(--wiki-border); background: var(--wiki-bg-subtle);">
    <h1 style="font-size: 2rem; font-weight: 700; color: var(--wiki-primary); margin-bottom: 0.625rem; letter-spacing: -0.5px;">
        SmartWorkz Core Documentation
    </h1>
    <p style="font-size: 1rem; color: var(--wiki-text-muted); margin: 0; max-width: 600px; line-height: 1.6;">
        Complete reference for building applications with SmartWorkz.Core infrastructure.
    </p>
</div>

<div style="padding: 2rem;">
    <div class="row g-3">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-6 col-lg-4">
                <div class="wiki-card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-folder2-open text-primary me-2" style="color: var(--wiki-primary) !important;"></i>
                            @category.Name
                        </h5>
                        <p class="card-text">
                            @category.Documents.Count document@(category.Documents.Count != 1 ? "s" : "")
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="/doc?slug=@category.Documents.First().Slug"
                           style="color: var(--wiki-primary); font-size: 0.875rem; font-weight: 500; text-decoration: none;">
                            Browse <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
