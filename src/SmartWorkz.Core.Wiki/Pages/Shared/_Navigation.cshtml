@inject WikiDocumentService WikiService

@{
    var categories = WikiService.GetCategories();
}

<div class="wiki-nav">
    <div class="accordion accordion-flush" id="wikiAccordion">
        @foreach (var category in categories)
        {
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse-@category.Slug"
                            aria-expanded="false">
                        @category.Name
                        <span class="badge ms-auto">@category.Documents.Count</span>
                    </button>
                </h2>
                <div id="collapse-@category.Slug"
                     class="accordion-collapse collapse"
                     data-bs-parent="#wikiAccordion">
                    <div class="accordion-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var doc in category.Documents)
                            {
                                <a href="/doc?slug=@doc.Slug"
                                   class="list-group-item list-group-item-action">
                                    @doc.Title
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
