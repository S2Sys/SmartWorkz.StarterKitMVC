<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartWorkz Core Wiki</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/wiki.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">
        <!-- Sidebar Navigation -->
        <nav class="wiki-sidebar">
            <div class="wiki-brand p-3 border-bottom" style="border-color: rgba(255, 255, 255, 0.1);">
                <a href="/" class="text-white text-decoration-none">
                    <i class="bi bi-book-fill"></i>
                    <strong>Core Wiki</strong>
                </a>
            </div>
            @await Html.PartialAsync("_Navigation")
        </nav>

        <!-- Main Content -->
        <main class="flex-grow-1 d-flex flex-column">
            <div class="wiki-header">
                <div class="container-fluid px-4">
                    <h1 class="mb-0">@ViewData["Title"]</h1>
                </div>
            </div>

            <div class="wiki-content flex-grow-1 overflow-auto">
                <div class="container-lg p-4">
                    @RenderBody()
                </div>
            </div>

            <footer class="border-top text-center py-4 mt-auto">
                <small>SmartWorkz Core &copy; 2026</small>
            </footer>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/wiki.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
