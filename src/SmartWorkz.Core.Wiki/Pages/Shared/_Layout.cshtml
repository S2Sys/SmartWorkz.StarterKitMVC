<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartWorkz Core Wiki</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
    <link href="~/css/wiki.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">

        <!-- Sidebar Navigation -->
        <nav class="wiki-sidebar">
            <div class="wiki-brand">
                <a href="/">
                    <i class="bi bi-book-fill"></i>
                    <strong>Core Wiki</strong>
                </a>
            </div>

            <!-- Search Box -->
            <div class="wiki-search-box">
                <i class="bi bi-search search-icon"></i>
                <input type="text"
                       id="wikiSearchInput"
                       placeholder="Search docs..."
                       autocomplete="off"
                       spellcheck="false" />
                <div class="wiki-search-results" id="wikiSearchResults"></div>
            </div>

            @await Html.PartialAsync("_Navigation")
        </nav>

        <!-- Mobile overlay -->
        <div class="wiki-overlay" id="wikiOverlay"></div>

        <!-- Main Content -->
        <main class="flex-grow-1 d-flex flex-column">
            <div class="wiki-header">
                <!-- Hamburger for mobile -->
                <button class="wiki-toggle-btn" id="wikiMenuToggle" aria-label="Toggle navigation">
                    <i class="bi bi-list" style="font-size: 1.25rem;"></i>
                </button>
                <h1 class="mb-0">@ViewData["Title"]</h1>
            </div>

            <div class="wiki-content flex-grow-1 overflow-auto">
                @RenderBody()
            </div>

            <footer class="border-top text-center py-3">
                <small style="color: var(--wiki-text-muted);">SmartWorkz Core &copy; 2026</small>
            </footer>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="~/js/wiki.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
