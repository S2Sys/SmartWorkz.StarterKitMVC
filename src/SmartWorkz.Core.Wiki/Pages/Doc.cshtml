@page
@model DocModel
@{
    ViewData["Title"] = Model.Document?.Title ?? "Documentation";
}

@if (Model.Document == null)
{
    <div class="p-4">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Document not found.</strong> Try browsing using the navigation sidebar.
        </div>
    </div>
}
else
{
    <div class="px-3 pt-3">
        <nav aria-label="breadcrumb" class="wiki-breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><span class="text-muted">@Model.Document.Category</span></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Document.Title</li>
            </ol>
        </nav>
    </div>

    <div class="wiki-doc-layout">
        <div class="wiki-article-wrapper">
            <article class="wiki-article">
                @Html.Raw(Model.HtmlContent)
            </article>

            <div class="wiki-doc-nav">
                <div>
                    @if (Model.PreviousDocument != null)
                    {
                        <a href="/doc?slug=@Model.PreviousDocument.Slug">
                            <small>&#8592; Previous</small>
                            @Model.PreviousDocument.Title
                        </a>
                    }
                </div>
                <div style="text-align: right;">
                    @if (Model.NextDocument != null)
                    {
                        <a href="/doc?slug=@Model.NextDocument.Slug">
                            <small>Next &#8594;</small>
                            @Model.NextDocument.Title
                        </a>
                    }
                </div>
            </div>
        </div>

        <aside class="wiki-toc">
            <div class="wiki-toc-inner">
                <!-- TOC populated by wiki.js -->
            </div>
        </aside>
    </div>
}
