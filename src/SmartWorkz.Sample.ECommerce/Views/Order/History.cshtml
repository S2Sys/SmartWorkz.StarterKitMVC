@model List<SmartWorkz.Sample.ECommerce.Application.DTOs.OrderDto>

@{ ViewData["Title"] = "Order History"; }

<h1 class="mb-4">My Orders</h1>

@if (Model != null && Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.PlacedAt.ToString("MMM dd, yyyy")</td>
                        <td>$@order.Total</td>
                        <td>
                            <span class="badge bg-info">@order.Status</span>
                        </td>
                        <td>
                            <a href="/order/detail/@order.Id" class="btn btn-sm btn-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        <p>No orders found.</p>
        <a href="/catalog" class="btn btn-primary">Start Shopping</a>
    </div>
}
