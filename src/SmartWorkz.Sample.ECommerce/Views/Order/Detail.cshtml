@model SmartWorkz.Sample.ECommerce.Application.DTOs.OrderDto

@{ ViewData["Title"] = "Order Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Order @Model?.Id</h1>
    <a href="/order/history" class="btn btn-secondary">Back to Orders</a>
</div>

@if (Model != null)
{
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Order Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Order ID:</strong> @Model.Id</p>
                    <p><strong>Date:</strong> @Model.PlacedAt.ToString("MMM dd, yyyy HH:mm")</p>
                    <p><strong>Status:</strong> <span class="badge bg-info">@Model.Status</span></p>
                    <p><strong>Total:</strong> $@Model.Total</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Order Items Count</h5>
                </div>
                <div class="card-body">
                    <p>@(Model?.Items?.Count ?? 0) item(s)</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Items != null && Model.Items.Count > 0)
    {
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Order Items</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>$@item.UnitPrice</td>
                                    <td>$@(item.UnitPrice * item.Quantity)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
