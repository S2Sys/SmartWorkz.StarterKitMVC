@{ ViewData["Title"] = "Error"; }

<div class="row">
    <div class="col-md-6 offset-md-3 text-center">
        <h1 class="display-4">⚠️ Oops!</h1>
        <p class="lead">An error occurred while processing your request.</p>

        <div class="alert alert-danger" role="alert">
            <p>We apologize for the inconvenience. Please try again or contact support if the problem persists.</p>
        </div>

        <a href="/" class="btn btn-primary btn-lg">Return to Home</a>
        <a href="/catalog" class="btn btn-secondary btn-lg">Browse Catalog</a>
    </div>
</div>
