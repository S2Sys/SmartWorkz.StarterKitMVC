@model List<SmartWorkz.Sample.ECommerce.Application.DTOs.CategoryDto>

@{ ViewData["Title"] = "Catalog"; }

<h1 class="mb-4">Product Catalog</h1>

<div class="row">
    @if (Model != null && Model.Count > 0)
    {
        @foreach (var category in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@category.Name</h5>
                        <p class="card-text">@(category.Description ?? "Browse products in this category")</p>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="/catalog/category/@category.Slug" class="btn btn-primary">View Products</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <p class="text-muted">No categories available.</p>
        </div>
    }
</div>
