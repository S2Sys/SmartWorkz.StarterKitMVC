@model SmartWorkz.Sample.ECommerce.Web.Models.ProductListViewModel

@{ ViewData["Title"] = "All Products"; }

<div class="container py-4">
    <h1 class="mb-4">All Products</h1>

    <!-- Sorting -->
    <div class="mb-4">
        <label for="sortBy" class="form-label">Sort By:</label>
        <form method="get" class="d-flex gap-2">
            <select name="sortBy" id="sortBy" class="form-select" style="max-width: 200px;" onchange="this.form.submit()">
                <option value="name" selected="@(Model.SortBy == "name")">Name (A-Z)</option>
                <option value="price-asc" selected="@(Model.SortBy == "price-asc")">Price (Low to High)</option>
                <option value="price-desc" selected="@(Model.SortBy == "price-desc")">Price (High to Low)</option>
            </select>
            <input type="hidden" name="page" value="1" />
        </form>
    </div>

    <!-- Products Grid -->
    <div class="row">
        @if (Model.Products != null && Model.Products.Count > 0)
        {
            @foreach (var product in Model.Products)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@(product.Description?.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)</p>
                            <p class="card-text">
                                <strong>Price:</strong> $@product.Price.ToString("F2")
                                <br />
                                <strong>Category:</strong> @product.CategoryName
                                <br />
                                <strong>Stock:</strong> <span class="badge bg-@(product.Stock > 10 ? "success" : product.Stock > 0 ? "warning" : "danger")">@product.Stock</span>
                            </p>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="/product/@product.Slug" class="btn btn-primary btn-sm">View Details</a>
                            <button class="btn btn-outline-success btn-sm" onclick="addToCart(@product.Id, 1)">Add to Cart</button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-muted">No products found.</p>
            </div>
        }
    </div>

    <!-- Paging -->
    @if (Model.Paging.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.Paging.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=1&sortBy=@Model.SortBy">First</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="?page=@Model.Paging.PreviousPageNumber&sortBy=@Model.SortBy">Previous</a>
                    </li>
                }

                @for (int i = Math.Max(1, Model.Paging.PageNumber - 2); i <= Math.Min(Model.Paging.TotalPages, Model.Paging.PageNumber + 2); i++)
                {
                    <li class="page-item @(i == Model.Paging.PageNumber ? "active" : "")">
                        <a class="page-link" href="?page=@i&sortBy=@Model.SortBy">@i</a>
                    </li>
                }

                @if (Model.Paging.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="?page=@Model.Paging.NextPageNumber&sortBy=@Model.SortBy">Next</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="?page=@Model.Paging.TotalPages&sortBy=@Model.SortBy">Last</a>
                    </li>
                }
            </ul>
        </nav>
        <div class="text-center text-muted small mt-2">
            Page @Model.Paging.PageNumber of @Model.Paging.TotalPages | Showing @Model.Products.Count of @Model.Paging.TotalItems products
        </div>
    }
</div>

<script>
    function addToCart(productId, quantity) {
        fetch(`/cart/add?productId=${productId}&quantity=${quantity}`, { method: 'POST' })
            .then(() => alert('Added to cart!'))
            .catch(e => alert('Error: ' + e));
    }
</script>
