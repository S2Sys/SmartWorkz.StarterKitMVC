<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopWorkz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-lg">
            <a class="navbar-brand" href="/">ShopWorkz</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/catalog">Catalog</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cart">
                        Cart <span class="badge bg-warning">@(TempData["CartCount"] ?? 0)</span>
                    </a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" href="/order/history">Orders</a></li>
                        <li class="nav-item">
                            <form method="post" action="/account/logout" style="display:inline">
                                <button class="nav-link btn btn-link" type="submit">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/account/register">Register</a></li>
                        <li class="nav-item"><a class="nav-link" href="/account/login">Login</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container-lg">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-light text-center py-4 mt-5">
        <p>&copy; 2026 ShopWorkz - E-commerce Demo</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
