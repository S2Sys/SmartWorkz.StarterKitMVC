@namespace SmartWorkz.Core.Web.Components.Data
@using SmartWorkz.Core.Web.Components.Data.Models

<div class="dashboard-container">
    @if (IsLoading)
    {
        <div class="row">
            @for (int i = 0; i < 4; i++)
            {
                <div class="col-lg-3 col-md-6 mb-4">
                    <div class="card placeholder-glow">
                        <div class="card-body">
                            <span class="placeholder col-8"></span>
                            <span class="placeholder col-5"></span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Stats != null && Stats.Count > 0)
    {
        <div class="row">
            @foreach (var stat in Stats)
            {
                <div class="col-lg-@(12 / ColumnsPerRow) col-md-6 mb-4">
                    <sw:Card Title="@stat.Label"
                            CssClass="stat-card h-100"
                            IsClickable="false">
                        <div class="stat-value @stat.ValueClass">@stat.Value</div>

                        @if (stat.Trend.HasValue)
                        {
                            <div class="stat-trend @(stat.TrendUp ? "text-success" : "text-danger") mt-2">
                                <i class="fa-solid @(stat.TrendUp ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i>
                                <span>@(stat.TrendUp ? "+" : "")@stat.Trend%</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(stat.Icon))
                        {
                            <div class="stat-icon-bg">
                                <i class="@stat.Icon"></i>
                            </div>
                        }
                    </sw:Card>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No statistics data available.
        </div>
    }

    @if (CustomContent != null)
    {
        <div class="mt-4">
            @CustomContent
        </div>
    }
</div>

@code {
    /// <summary>List of statistics to display.</summary>
    [Parameter]
    public List<StatCardData>? Stats { get; set; }

    /// <summary>Number of columns per row (default 4).</summary>
    [Parameter]
    public int ColumnsPerRow { get; set; } = 4;

    /// <summary>Show loading skeleton.</summary>
    [Parameter]
    public bool IsLoading { get; set; } = false;

    /// <summary>Custom content below stats (charts, etc.).</summary>
    [Parameter]
    public RenderFragment? CustomContent { get; set; }

    /// <summary>CSS class for dashboard container.</summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>Callback when stat card is clicked.</summary>
    [Parameter]
    public EventCallback<StatCardData> OnStatClick { get; set; }
}

<style>
    .dashboard-container {
        padding: 0;
    }

    .stat-card {
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-2px);
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1;
    }

    .stat-trend {
        font-size: 0.95rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .stat-icon-bg {
        position: absolute;
        top: -10px;
        right: -10px;
        width: 80px;
        height: 80px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        opacity: 0.3;
    }

    @media (max-width: 768px) {
        .stat-value {
            font-size: 1.8rem;
        }
    }
</style>
