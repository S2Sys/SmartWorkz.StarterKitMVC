@namespace SmartWorkz.Core.Web.Components.Data
@using SmartWorkz.Core.Web.Components.Data.Models

<div class="timeline-container @GetTimelineClasses()">
    @if (Events != null && Events.Count > 0)
    {
        var sortedEvents = ReverseOrder ? Events.AsEnumerable().Reverse() : Events.AsEnumerable();

        @foreach (var evt in sortedEvents)
        {
            <div class="timeline-item @GetEventPositionClass()" data-event-id="@evt.Id">
                <!-- Timeline indicator -->
                <div class="timeline-indicator bg-@evt.IconColor">
                    @if (!string.IsNullOrEmpty(evt.IconClass))
                    {
                        <i class="@evt.IconClass"></i>
                    }
                    else if (ShowAvatars && !string.IsNullOrEmpty(evt.AvatarUrl))
                    {
                        <img src="@evt.AvatarUrl" alt="@evt.Actor" class="avatar-sm rounded-circle" />
                    }
                </div>

                <!-- Timeline content -->
                <div class="timeline-content">
                    <div class="timeline-header">
                        <h5 class="timeline-title">@evt.Title</h5>
                        <small class="timeline-date text-muted">
                            @FormatDate(evt.Timestamp)
                        </small>
                    </div>

                    @if (!string.IsNullOrEmpty(evt.Description))
                    {
                        <p class="timeline-description">
                            @evt.Description
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(evt.Actor))
                    {
                        <div class="timeline-actor text-muted">
                            <small>
                                <i class="fa-solid fa-user"></i>
                                @evt.Actor
                            </small>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(evt.BadgeText))
                    {
                        <div class="mt-2">
                            <span class="badge bg-info">@evt.BadgeText</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info mb-0">No timeline events to display.</div>
    }
</div>

@code {
    /// <summary>List of timeline events.</summary>
    [Parameter]
    public List<TimelineEvent>? Events { get; set; }

    /// <summary>Timeline layout (Vertical or Horizontal).</summary>
    [Parameter]
    public TimelineLayout Layout { get; set; } = TimelineLayout.Vertical;

    /// <summary>Timeline position (Left, Center, Right).</summary>
    [Parameter]
    public TimelinePosition Position { get; set; } = TimelinePosition.Left;

    /// <summary>Timeline indicator size.</summary>
    [Parameter]
    public TimelineSize IndicatorSize { get; set; } = TimelineSize.Medium;

    /// <summary>Date format string.</summary>
    [Parameter]
    public string DateFormat { get; set; } = "MMM dd, yyyy";

    /// <summary>Include time in timestamp.</summary>
    [Parameter]
    public bool IncludeTime { get; set; } = false;

    /// <summary>Reverse chronological order (newest first).</summary>
    [Parameter]
    public bool ReverseOrder { get; set; } = false;

    /// <summary>Show avatars for events.</summary>
    [Parameter]
    public bool ShowAvatars { get; set; } = false;

    /// <summary>Custom CSS class.</summary>
    [Parameter]
    public string? CssClass { get; set; }

    private string GetTimelineClasses()
    {
        var classes = new List<string> { "timeline" };
        classes.Add($"timeline-{Layout.ToString().ToLower()}");
        classes.Add($"timeline-{Position.ToString().ToLower()}");
        classes.Add($"timeline-{IndicatorSize.ToString().ToLower()}");
        if (!string.IsNullOrEmpty(CssClass)) classes.Add(CssClass);
        return string.Join(" ", classes);
    }

    private string GetEventPositionClass()
    {
        return Position switch
        {
            TimelinePosition.Center => "timeline-event-center",
            TimelinePosition.Right => "timeline-event-right",
            _ => "timeline-event-left"
        };
    }

    private string FormatDate(DateTime date)
    {
        if (IncludeTime)
            return date.ToString(DateFormat + " HH:mm");
        return date.ToString(DateFormat);
    }
}

<style>
    .timeline {
        position: relative;
        padding: 2rem 0;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 40px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--bs-light);
    }

    .timeline-vertical {
        padding-left: 80px;
    }

    .timeline-vertical::before {
        left: 40px;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 2.5rem;
        animation: fadeInUp 0.5s ease forwards;
        opacity: 0;
        animation-fill-mode: forwards;
    }

    .timeline-item:nth-child(1) { animation-delay: 0.1s; }
    .timeline-item:nth-child(2) { animation-delay: 0.2s; }
    .timeline-item:nth-child(3) { animation-delay: 0.3s; }
    .timeline-item:nth-child(4) { animation-delay: 0.4s; }
    .timeline-item:nth-child(5) { animation-delay: 0.5s; }
    .timeline-item:nth-child(n+6) { animation-delay: 0.6s; }

    .timeline-indicator {
        position: absolute;
        left: -60px;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bs-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
        border: 4px solid white;
        box-shadow: 0 0 0 2px var(--bs-light);
        font-size: 1rem;
    }

    .timeline-small .timeline-indicator {
        width: 24px;
        height: 24px;
        left: -52px;
        font-size: 0.75rem;
    }

    .timeline-large .timeline-indicator {
        width: 56px;
        height: 56px;
        left: -68px;
        font-size: 1.25rem;
    }

    .timeline-content {
        background: white;
        border: 1px solid var(--bs-border-color);
        border-radius: 0.375rem;
        padding: 1.5rem;
        position: relative;
    }

    .timeline-content::before {
        content: '';
        position: absolute;
        left: -8px;
        top: 20px;
        width: 0;
        height: 0;
        border-left: 8px solid white;
        border-top: 5px solid transparent;
        border-bottom: 5px solid transparent;
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .timeline-title {
        margin: 0;
        font-weight: 600;
    }

    .timeline-date {
        white-space: nowrap;
        font-size: 0.85rem;
    }

    .timeline-description {
        margin: 0.5rem 0 0 0;
        color: var(--bs-body-color);
    }

    .timeline-actor {
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }

    .bg-primary { background-color: var(--bs-primary) !important; }
    .bg-success { background-color: var(--bs-success) !important; }
    .bg-danger { background-color: var(--bs-danger) !important; }
    .bg-warning { background-color: var(--bs-warning) !important; }
    .bg-info { background-color: var(--bs-info) !important; }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .timeline {
            padding-left: 0;
        }

        .timeline::before {
            left: 20px;
        }

        .timeline-vertical {
            padding-left: 60px;
        }

        .timeline-indicator {
            left: -40px;
            width: 32px;
            height: 32px;
            border-width: 3px;
        }

        .timeline-content {
            padding: 1rem;
        }

        .timeline-content::before {
            left: -6px;
            border-left-width: 6px;
        }
    }
</style>
