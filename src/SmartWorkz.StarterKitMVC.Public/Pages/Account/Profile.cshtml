@page
@model ProfileModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5" style="max-width: 800px;">
    <div class="d-flex align-items-center mb-4">
        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3"
             style="width:56px;height:56px;font-size:22px;color:white;">
            <i class="bi bi-person"></i>
        </div>
        <div>
            <h2 class="mb-0 fw-bold">@Model.DisplayName</h2>
            <span class="text-muted small">@Model.Email</span>
        </div>
    </div>

    <!-- Identity -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-person-badge me-2 text-primary"></i>Identity
        </div>
        <div class="card-body">
            <table class="table table-sm mb-0">
                <tbody>
                    <tr><td class="text-muted" style="width:160px;">User ID</td><td><code>@Model.UserId</code></td></tr>
                    <tr><td class="text-muted">Email</td><td>@Model.Email</td></tr>
                    <tr><td class="text-muted">Display Name</td><td>@Model.DisplayName</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Roles -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-person-fill-gear me-2 text-success"></i>Roles
            <span class="badge bg-success ms-2">@Model.Roles.Count</span>
        </div>
        <div class="card-body">
            @if (Model.Roles.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var role in Model.Roles)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">@role</span>
                    }
                </div>
            }
            else
            {
                <span class="text-muted small">No roles assigned</span>
            }
        </div>
    </div>

    <!-- Permissions -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-shield-check me-2 text-warning"></i>Permissions
            <span class="badge bg-warning text-dark ms-2">@Model.Permissions.Count</span>
        </div>
        <div class="card-body">
            @if (Model.Permissions.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var perm in Model.Permissions)
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">@perm</span>
                    }
                </div>
            }
            else
            {
                <span class="text-muted small">No direct permissions</span>
            }
        </div>
    </div>

    <!-- All Cookie Claims -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom fw-semibold">
            <i class="bi bi-key me-2 text-secondary"></i>Cookie Claims
            <span class="badge bg-secondary ms-2">@Model.AllClaims.Count</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:200px;">Claim Type</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (type, value) in Model.AllClaims)
                    {
                        <tr>
                            <td><code class="text-muted small">@type</code></td>
                            <td class="small">@value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <form method="post" asp-page="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger me-2">
                <i class="bi bi-box-arrow-right me-1"></i>Sign Out
            </button>
        </form>
    </div>
</div>
