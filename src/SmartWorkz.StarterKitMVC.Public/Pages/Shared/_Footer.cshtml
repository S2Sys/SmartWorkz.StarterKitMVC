@* Modern Footer - Professional Design *@
@{
    var year = DateTime.UtcNow.Year;
}
<footer class="text-light py-5 mt-auto" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-top: 1px solid rgba(255,255,255,0.1);">
    <div class="container">
        <div class="row g-5">
            <!-- Brand Column -->
            <div class="col-lg-4 col-md-6">
                <h5 class="fw-bold mb-3 d-flex align-items-center">
                    <i class="bi bi-rocket-takeoff me-2" style="color: #f59e0b; font-size: 1.5rem;"></i>
                    <span>SmartWorkz</span>
                </h5>
                <p class="text-gray-400 mb-4" style="line-height: 1.7;">
                    Enterprise-grade ASP.NET Core MVC boilerplate built for modern development with clean architecture, multi-tenancy, and professional design.
                </p>
                <div class="d-flex gap-3">
                    <a href="https://github.com/S2Sys/SmartWorkz.StarterKitMVC" target="_blank" class="btn btn-icon" style="background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%;">
                        <i class="bi bi-github"></i>
                    </a>
                    <a href="#" class="btn btn-icon" style="background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%;">
                        <i class="bi bi-linkedin"></i>
                    </a>
                    <a href="#" class="btn btn-icon" style="background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%;">
                        <i class="bi bi-twitter-x"></i>
                    </a>
                    <a href="#" class="btn btn-icon" style="background: rgba(255,255,255,0.1); color: white; border: none; width: 40px; height: 40px; border-radius: 50%;">
                        <i class="bi bi-youtube"></i>
                    </a>
                </div>
            </div>

            <!-- Product Column -->
            <div class="col-lg-2 col-md-6">
                <h6 class="fw-bold mb-4 text-uppercase" style="letter-spacing: 0.5px; font-size: 0.875rem;">Product</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-3"><a asp-page="/Features" class="footer-link" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;">Features</a></li>
                    <li class="mb-3"><a asp-page="/About" class="footer-link" style="color: #cbd5e1; text-decoration: none;">About</a></li>
                    <li class="mb-3"><a href="/swagger" class="footer-link" style="color: #cbd5e1; text-decoration: none;">API Docs</a></li>
                    <li class="mb-3"><a href="https://github.com/S2Sys/SmartWorkz.StarterKitMVC" target="_blank" class="footer-link" style="color: #cbd5e1; text-decoration: none;">GitHub</a></li>
                </ul>
            </div>

            <!-- Company Column -->
            <div class="col-lg-2 col-md-6">
                <h6 class="fw-bold mb-4 text-uppercase" style="letter-spacing: 0.5px; font-size: 0.875rem;">Company</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-3"><a asp-page="/About" class="footer-link" style="color: #cbd5e1; text-decoration: none;">About Us</a></li>
                    <li class="mb-3"><a asp-page="/Contact" class="footer-link" style="color: #cbd5e1; text-decoration: none;">Contact</a></li>
                    <li class="mb-3"><a asp-page="/Privacy" class="footer-link" style="color: #cbd5e1; text-decoration: none;">Privacy</a></li>
                    <li class="mb-3"><a asp-page="/Terms" class="footer-link" style="color: #cbd5e1; text-decoration: none;">Terms</a></li>
                </ul>
            </div>

            <!-- Newsletter Column -->
            <div class="col-lg-4 col-md-6">
                <h6 class="fw-bold mb-4 text-uppercase" style="letter-spacing: 0.5px; font-size: 0.875rem;">Newsletter</h6>
                <p class="text-gray-400 small mb-3">Get updates on new features and latest news.</p>
                <form class="d-flex gap-2 mb-3">
                    <input type="email" class="form-control form-control-sm"
                           placeholder="your@email.com"
                           style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 0.5rem;">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-send"></i>
                    </button>
                </form>
                <div>
                    <small style="color: #cbd5e1;">
                        <i class="bi bi-envelope me-1"></i>hello@smartworkz.com
                    </small>
                </div>
            </div>
        </div>

        <hr style="border-color: rgba(255,255,255,0.1); margin: 2rem 0;">

        <!-- Bottom Bar -->
        <div class="row align-items-center">
            <div class="col-md-6 text-center text-md-start">
                <p style="color: #cbd5e1; font-size: 0.875rem; margin: 0;">
                    &copy; @year SmartWorkz. All rights reserved. Built with <i class="bi bi-heart-fill" style="color: #ef4444;"></i> using .NET 9
                </p>
            </div>
            <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                <a asp-page="/Privacy" class="footer-link" style="color: #cbd5e1; text-decoration: none; margin-right: 1.5rem; font-size: 0.875rem;">Privacy</a>
                <a asp-page="/Terms" class="footer-link" style="color: #cbd5e1; text-decoration: none; margin-right: 1.5rem; font-size: 0.875rem;">Terms</a>
                <a asp-page="/Contact" class="footer-link" style="color: #cbd5e1; text-decoration: none; font-size: 0.875rem;">Contact</a>
            </div>
        </div>
    </div>
</footer>

<style>
.text-gray-400 {
    color: #9ca3af;
}

.footer-link {
    transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.footer-link:hover {
    color: #f59e0b !important;
}

.btn-icon:hover {
    background: rgba(255, 255, 255, 0.2) !important;
    transform: translateY(-2px);
}
</style>
