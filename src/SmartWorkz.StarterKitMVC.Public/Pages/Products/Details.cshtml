@page "/Products/{slug}"
@model SmartWorkz.StarterKitMVC.Public.Pages.Products.DetailsModel

@{
    ViewData["Title"] = Model.Product?.Name ?? "Product";
}

<section class="py-5 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="@Url.Page("/Index")">Home</a></li>
                <li class="breadcrumb-item"><a href="@Url.Page("./Index")">Products</a></li>
                <li class="breadcrumb-item active">@Model.Product?.Name</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-5 bg-light text-center">
                        <i class="bi bi-box-seam display-1 text-muted"></i>
                        <p class="text-muted mt-3">Product image placeholder</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h1>@Model.Product?.Name</h1>

                <div class="mb-3">
                    <span class="badge bg-primary me-2">@Model.Product?.SKU</span>
                    @if (Model.Product?.IsFeatured == true)
                    {
                        <span class="badge bg-warning">Featured</span>
                    }
                </div>

                <h2 class="h3 mb-3">${{ Model.Product?.Price:0.00 }}</h2>

                <div class="mb-4">
                    @if (Model.Product?.Stock > 0)
                    {
                        <span class="badge bg-success">In Stock</span>
                        <p class="text-muted small mt-2">@Model.Product?.Stock units available</p>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Out of Stock</span>
                    }
                </div>

                <div class="mb-4">
                    <h5>Category</h5>
                    <p>@Model.Product?.Category?.Name</p>
                </div>

                <div class="mb-4">
                    <h5>Description</h5>
                    <p>@Model.Product?.Description</p>
                </div>

                <div class="mb-4">
                    <h5>Pricing</h5>
                    <table class="table table-sm">
                        <tr>
                            <td>Price</td>
                            <td class="text-end">${{ Model.Product?.Price:0.00 }}</td>
                        </tr>
                        @if (Model.Product?.CostPrice.HasValue == true)
                        {
                            <tr>
                                <td>Cost Price</td>
                                <td class="text-end">${{ Model.Product?.CostPrice:0.00 }}</td>
                            </tr>
                        }
                    </table>
                </div>

                <div class="d-flex gap-2">
                    @if (Model.Product?.Stock > 0)
                    {
                        <button class="btn btn-primary" disabled>
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                    }
                    <a href="@Url.Page("./Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Products
                    </a>
                </div>
            </div>
        </div>

        <hr class="my-5">

        <div class="row">
            <div class="col-md-6">
                <h5>Metadata</h5>
                <table class="table table-sm">
                    <tr>
                        <td>Created</td>
                        <td>@Model.Product?.CreatedAt.ToString("g")</td>
                    </tr>
                    <tr>
                        <td>Status</td>
                        <td>
                            <span class="badge @(Model.Product?.IsActive == true ? "bg-success" : "bg-secondary")">
                                @Model.Product?.Status
                            </span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</section>
