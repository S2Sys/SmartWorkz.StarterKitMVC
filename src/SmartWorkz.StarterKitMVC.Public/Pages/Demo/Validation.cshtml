@page
@model ValidationModel

@{
    ViewData["Title"] = "Validation Demo";
}

<section class="py-5 bg-light">
    <div class="container">
        <h1>Validation System Demo</h1>
        <p class="lead">Demonstrates simple validation using MessageKey error messages that are translated at runtime</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">Validation Form</h5>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <!-- Full Name -->
                            <div class="mb-3">
                                <label asp-for="Input.FullName" class="form-label"></label>
                                <input asp-for="Input.FullName" class="form-control" placeholder="John Doe" />
                                <span asp-validation-for="Input.FullName" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">2-100 characters required</small>
                            </div>

                            <!-- Email -->
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label"></label>
                                <input asp-for="Input.Email" class="form-control" type="email" placeholder="john@example.com" />
                                <span asp-validation-for="Input.Email" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">Valid email address required</small>
                            </div>

                            <!-- Age (optional) -->
                            <div class="mb-3">
                                <label asp-for="Input.Age" class="form-label"></label>
                                <input asp-for="Input.Age" class="form-control" type="number" placeholder="25" />
                                <span asp-validation-for="Input.Age" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">Must be between 18 and 120 (optional)</small>
                            </div>

                            <!-- Website URL (optional) -->
                            <div class="mb-3">
                                <label asp-for="Input.WebsiteUrl" class="form-label"></label>
                                <input asp-for="Input.WebsiteUrl" class="form-control" type="url" placeholder="https://example.com" />
                                <span asp-validation-for="Input.WebsiteUrl" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">Valid URL format (optional)</small>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label"></label>
                                <input asp-for="Input.Password" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="Input.Password" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">8-100 characters required</small>
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-3">
                                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="Input.ConfirmPassword" class="invalid-feedback d-block"></span>
                                <small class="text-muted d-block mt-1">Must match password above</small>
                            </div>

                            <!-- Buttons -->
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i> Validate
                                </button>
                                <a href="@Url.Page("/Index")" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Back
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- How It Works -->
                <div class="alert alert-info mt-4">
                    <h6 class="alert-heading">How It Works</h6>
                    <ul class="mb-0">
                        <li>All validation attributes use <code>MessageKey</code> constants in <code>ErrorMessage</code></li>
                        <li>Validation messages are automatically translated via <code>ITranslationService</code></li>
                        <li>Try submitting empty or invalid data to see translated error messages</li>
                        <li>Optional fields: Age, WebsiteUrl (leave blank to skip validation)</li>
                        <li>Required fields: FullName, Email, Password, ConfirmPassword</li>
                        <li>Error messages are translated at validation time from the database</li>
                    </ul>
                </div>

                <!-- Validation Attributes -->
                <div class="alert alert-secondary mt-4">
                    <h6 class="alert-heading">Validation Attributes Demonstrated</h6>
                    <ul class="mb-0">
                        <li><code>[Required(ErrorMessage = MessageKeys.Validation.Required)]</code> — Field is mandatory</li>
                        <li><code>[StringLength(max, MinimumLength = min, ErrorMessage = ...)]</code> — Text length constraints</li>
                        <li><code>[EmailAddress(ErrorMessage = MessageKeys.Validation.EmailInvalid)]</code> — Valid email format</li>
                        <li><code>[Range(min, max, ErrorMessage = ...)]</code> — Numeric range validation</li>
                        <li><code>[RegularExpression(pattern, ErrorMessage = ...)]</code> — Pattern matching</li>
                        <li><code>[Compare(otherProperty, ErrorMessage = ...)]</code> — Field comparison (password match)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
