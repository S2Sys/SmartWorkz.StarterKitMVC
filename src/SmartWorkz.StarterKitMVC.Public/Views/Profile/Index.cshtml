@model SmartWorkz.StarterKitMVC.Public.Controllers.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="py-5">
    <div class="container">
        <div class="row">
            <!-- Profile Info -->
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Profile Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <img src="@Model.Avatar" alt="Profile" class="img-fluid rounded">
                            </div>
                            <div class="col-md-9">
                                <h4>@Model.FirstName @Model.LastName</h4>
                                <p class="text-muted">@Model.Email</p>
                                <p>@Model.Bio</p>
                                <a href="/profile/edit" class="btn btn-primary">Edit Profile</a>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <p class="text-muted small">EMAIL</p>
                                <p>@Model.Email</p>
                                @if (Model.IsEmailVerified)
                                {
                                    <span class="badge bg-success">Verified</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Unverified</span>
                                }
                            </div>
                            <div class="col-md-6 mb-3">
                                <p class="text-muted small">PHONE</p>
                                <p>@Model.PhoneNumber</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <p class="text-muted small">DATE OF BIRTH</p>
                                <p>@(Model.DateOfBirth?.ToString("MMMM dd, yyyy") ?? "Not specified")</p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <p class="text-muted small">MEMBER SINCE</p>
                                <p>@Model.JoinedDate.ToString("MMMM dd, yyyy")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Security Settings -->
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Security</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <p class="small text-muted">PASSWORD</p>
                            <a href="/profile/changepassword" class="btn btn-sm btn-outline-primary w-100">
                                Change Password
                            </a>
                        </div>

                        <hr>

                        <div>
                            <p class="small text-muted">TWO-FACTOR AUTHENTICATION</p>
                            @if (Model.IsTwoFactorEnabled)
                            {
                                <p><span class="badge bg-success">Enabled</span></p>
                                <form method="post" action="/profile/disable2fa" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Disable 2FA</button>
                                </form>
                            }
                            else
                            {
                                <p><span class="badge bg-secondary">Disabled</span></p>
                                <a href="/profile/enable2fa" class="btn btn-sm btn-outline-primary w-100">
                                    Enable 2FA
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Account</h5>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">Manage your account settings</p>
                        <button type="button" class="btn btn-sm btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Account Modal -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete your account? This action cannot be undone.</p>
                <p class="text-muted small">All your data will be permanently deleted.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" action="/profile/delete" style="display: inline;">
                    <button type="submit" class="btn btn-danger">Delete Account</button>
                </form>
            </div>
        </div>
    </div>
</div>
