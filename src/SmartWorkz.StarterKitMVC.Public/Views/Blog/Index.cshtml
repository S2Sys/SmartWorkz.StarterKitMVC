@model SmartWorkz.StarterKitMVC.Public.Controllers.BlogListViewModel
@{
    ViewData["Title"] = "Blog";
}

<div class="py-5 bg-light">
    <div class="container">
        <h1 class="mb-2">Blog</h1>
        <p class="lead text-muted">Insights and articles about web development, technology, and best practices</p>
    </div>
</div>

<div class="py-5">
    <div class="container">
        <div class="row">
            <!-- Blog Posts -->
            <div class="col-lg-8">
                @if (Model.Posts.Count == 0)
                {
                    <div class="alert alert-info">No blog posts found</div>
                }
                else
                {
                    @foreach (var post in Model.Posts)
                    {
                        <article class="mb-5 pb-5 border-bottom">
                            <h2 class="mb-2">
                                <a href="/blog/post/@post.Slug" class="text-decoration-none">@post.Title</a>
                            </h2>
                            <p class="text-muted small mb-3">
                                By <strong>@post.Author</strong> on <strong>@post.PublishedAt.ToString("MMMM dd, yyyy")</strong>
                                <span class="ms-3">
                                    <i class="fas fa-eye"></i> @post.Views views
                                </span>
                            </p>
                            <p class="lead">@post.Excerpt</p>
                            <div class="mb-3">
                                @foreach (var tag in post.Tags.Split(','))
                                {
                                    <a href="/blog?tag=@tag.Trim()" class="badge bg-light text-dark text-decoration-none">@tag.Trim()</a>
                                }
                            </div>
                            <a href="/blog/post/@post.Slug" class="btn btn-outline-primary">Read More</a>
                        </article>
                    }
                }

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-5">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/blog?page=1">First</a>
                            </li>
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/blog?page=@(Model.CurrentPage - 1)">Previous</a>
                            </li>

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="/blog?page=@i">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="/blog?page=@(Model.CurrentPage + 1)">Next</a>
                            </li>
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="/blog?page=@Model.TotalPages">Last</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Search -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Search</h5>
                        <form method="get" action="/blog/search" class="d-flex gap-2">
                            <input type="text" name="query" class="form-control" placeholder="Search posts..." />
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Popular Tags -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Popular Tags</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var tag in Model.PopularTags)
                            {
                                <a href="/blog?tag=@tag" class="badge bg-light text-dark text-decoration-none">
                                    <i class="fas fa-tag"></i> @tag
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
