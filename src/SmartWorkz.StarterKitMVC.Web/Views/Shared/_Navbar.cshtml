@* Modern Navbar - Professional Design *@
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<nav class="navbar navbar-expand-lg sticky-top" id="mainNav" style="background: white; border-bottom: 1px solid #e2e8f0;">
    <div class="container-fluid px-4">
        <!-- Brand -->
        <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index" style="color: #6366f1; font-size: 1.5rem; letter-spacing: -0.5px;">
            <i class="bi bi-rocket-takeoff me-2" style="color: #f59e0b;"></i>
            <span>SmartWorkz<span style="color: #f59e0b;">.</span></span>
        </a>

        <!-- Navbar Toggler -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <i class="bi bi-list" style="font-size: 1.5rem; color: #6366f1;"></i>
        </button>

        <!-- Navbar Content -->
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-1">
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Index" && currentController == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index" style="color: #475569; font-weight: 500;">
                        <i class="bi bi-house me-1"></i>Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "About" ? "active" : "")"
                       asp-controller="Home" asp-action="About" style="color: #475569; font-weight: 500;">
                        <i class="bi bi-info-circle me-1"></i>About
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentAction == "Features" ? "active" : "")"
                       asp-controller="Home" asp-action="Features" style="color: #475569; font-weight: 500;">
                        <i class="bi bi-lightning-charge me-1"></i>Features
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: #475569; font-weight: 500;">
                        <i class="bi bi-file-earmark me-1"></i>More
                    </a>
                    <ul class="dropdown-menu" style="border-radius: 0.75rem; border: 1px solid #e2e8f0; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
                        <li><a class="dropdown-item" asp-controller="Home" asp-action="Privacy"><i class="bi bi-shield-check me-2"></i>Privacy</a></li>
                        <li><a class="dropdown-item" asp-controller="Home" asp-action="Terms"><i class="bi bi-file-text me-2"></i>Terms</a></li>
                        <li><a class="dropdown-item" asp-controller="Home" asp-action="Contact"><i class="bi bi-envelope me-2"></i>Contact</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin</a></li>
                    </ul>
                </li>
            </ul>

            <!-- Search Form -->
            <form class="d-flex me-3 d-none d-lg-flex me-lg-3" asp-controller="Home" asp-action="Search" method="get">
                <div class="input-group" style="width: 200px;">
                    <input class="form-control" type="search" name="q" placeholder="Search..."
                           aria-label="Search" style="border-radius: 0.75rem 0 0 0.75rem; border: 1px solid #e2e8f0; background: #f8fafc;">
                    <button class="btn" type="submit" style="background: #f1f5f9; border: 1px solid #e2e8f0; border-left: none; border-radius: 0 0.75rem 0.75rem 0;">
                        <i class="bi bi-search" style="color: #6366f1;"></i>
                    </button>
                </div>
            </form>

            <!-- Right Actions -->
            <div class="d-flex align-items-center gap-2">
                <!-- Theme Toggle -->
                <button class="btn btn-icon" id="themeToggle" title="Toggle theme" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <i class="bi bi-moon-stars" id="themeIcon" style="color: #6366f1;"></i>
                </button>

                <!-- Auth Buttons -->
                <a asp-controller="Account" asp-action="Login" class="btn btn-secondary d-none d-md-inline-block">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
                    <i class="bi bi-person-plus me-1"></i>Sign Up
                </a>
            </div>
        </div>
    </div>
</nav>

<style>
.navbar-nav .nav-link {
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.navbar-nav .nav-link:hover {
    color: #6366f1 !important;
}

.navbar-nav .nav-link.active {
    color: #6366f1 !important;
}

.navbar-nav .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    border-radius: 2px;
}

.dropdown-menu .dropdown-item {
    color: #475569;
    transition: all 0.2s ease;
}

.dropdown-menu .dropdown-item:hover {
    background: linear-gradient(135deg, #c7d2fe, #ddd6fe);
    color: #6366f1;
}
</style>
