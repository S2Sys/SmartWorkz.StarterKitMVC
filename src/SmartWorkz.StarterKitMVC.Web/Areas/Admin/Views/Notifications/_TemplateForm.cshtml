@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.NotificationTemplateFormViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var actionUrl = Model.Id.HasValue 
        ? Url.Action("TemplateEdit", "Notifications", new { area = "Admin", id = Model.Id }) 
        : Url.Action("TemplateCreate", "Notifications", new { area = "Admin" });
    var token = Antiforgery.GetAndStoreTokens(Context);
}

<form id="templateForm" action="@actionUrl" method="post">
    <input type="hidden" name="@token.FormFieldName" value="@token.RequestToken" />
    <input type="hidden" asp-for="Id" />
    
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
            @if (Model.Id.HasValue)
            {
                <input asp-for="Key" class="form-control" placeholder="e.g., welcome_email" readonly />
            }
            else
            {
                <input asp-for="Key" class="form-control" placeholder="e.g., welcome_email" />
            }
            <span asp-validation-for="Key" class="text-danger"></span>
            <small class="text-muted">Unique identifier (lowercase, underscores only)</small>
        </div>
        
        <div class="col-md-6">
            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control" placeholder="e.g., Welcome Email" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        
        <div class="col-12">
            <label asp-for="Description" class="form-label">Description</label>
            <input asp-for="Description" class="form-control" placeholder="Brief description of when this template is used" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        
        <div class="col-md-6">
            <label asp-for="Channel" class="form-label">Channel <span class="text-danger">*</span></label>
            <select asp-for="Channel" class="form-select">
                <option value="Email">Email</option>
                <option value="SMS">SMS</option>
                <option value="Push">Push Notification</option>
                <option value="InApp">In-App</option>
            </select>
            <span asp-validation-for="Channel" class="text-danger"></span>
        </div>
        
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <div class="form-check form-switch mt-2">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
        
        <div class="col-12" id="subjectField">
            <label asp-for="Subject" class="form-label">Subject</label>
            <input asp-for="Subject" class="form-control" placeholder="Email subject line with {{placeholders}}" />
            <span asp-validation-for="Subject" class="text-danger"></span>
        </div>
        
        <div class="col-12">
            <label asp-for="Body" class="form-label">Body (Plain Text) <span class="text-danger">*</span></label>
            <textarea asp-for="Body" class="form-control" rows="4" 
                      placeholder="Plain text message with {{placeholders}}"></textarea>
            <span asp-validation-for="Body" class="text-danger"></span>
        </div>
        
        <div class="col-12" id="bodyHtmlField">
            <label asp-for="BodyHtml" class="form-label">Body (HTML)</label>
            <textarea asp-for="BodyHtml" class="form-control font-monospace" rows="6" 
                      placeholder="<html>HTML version with {{placeholders}}</html>"></textarea>
            <span asp-validation-for="BodyHtml" class="text-danger"></span>
        </div>
        
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-header py-2">
                    <i class="bi bi-braces me-1"></i>Available Placeholders
                </div>
                <div class="card-body py-2">
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var placeholder in Model.AvailablePlaceholders)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary placeholder-btn" 
                                    data-placeholder="@placeholder" title="Click to copy">
                                <code>@placeholder</code>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
(function() {
    // Toggle subject and HTML body fields based on channel
    const channelSelect = document.getElementById('Channel');
    const subjectField = document.getElementById('subjectField');
    const bodyHtmlField = document.getElementById('bodyHtmlField');
    
    function updateFieldVisibility() {
        const channel = channelSelect.value;
        const showEmailFields = channel === 'Email';
        const showHtmlField = channel === 'Email' || channel === 'InApp';
        
        subjectField.style.display = showEmailFields ? 'block' : 'none';
        bodyHtmlField.style.display = showHtmlField ? 'block' : 'none';
    }
    
    channelSelect?.addEventListener('change', updateFieldVisibility);
    updateFieldVisibility();
    
    // Placeholder copy functionality
    document.querySelectorAll('.placeholder-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const placeholder = this.dataset.placeholder;
            navigator.clipboard.writeText(placeholder).then(() => {
                SW.toast?.success?.('Copied: ' + placeholder) || alert('Copied: ' + placeholder);
            });
        });
    });
})();
</script>
