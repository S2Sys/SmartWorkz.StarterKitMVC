@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ClaimTypeFormViewModel
@{
    ViewData["Title"] = $"Edit Claim Type: {Model.Name}";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card admin-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-pencil me-2"></i>Edit Claim Type</span>
                @if (Model.IsSystem)
                {
                    <span class="badge bg-secondary">System</span>
                }
            </div>
            <div class="card-body">
                <form asp-action="ClaimTypeEdit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Key" class="form-label">Key</label>
                            <input asp-for="Key" class="form-control" readonly disabled />
                            <small class="text-muted">Key cannot be changed</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <input asp-for="Category" class="form-control" list="categoryList" />
                            <datalist id="categoryList">
                                @foreach (var cat in Model.AvailableCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </datalist>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Icon" class="form-label">Icon</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    @if (!string.IsNullOrEmpty(Model.Icon))
                                    {
                                        <i class="bi @Model.Icon"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-palette"></i>
                                    }
                                </span>
                                <input asp-for="Icon" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="AllowMultiple" class="form-check-input" type="checkbox" />
                            <label asp-for="AllowMultiple" class="form-check-label">
                                Allow Multiple Values
                            </label>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Claims" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
