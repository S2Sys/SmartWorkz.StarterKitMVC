@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.RoleClaimsViewModel
@{
    ViewData["Title"] = $"Claims for Role: {Model.RoleId}";
}

@section PageActions {
    <a asp-action="Claims" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Claims
    </a>
}

<!-- Role Selector -->
<div class="card admin-card mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-auto">
                <label class="form-label mb-0 fw-bold">Select Role:</label>
            </div>
            <div class="col-md-4">
                <select id="roleSelector" class="form-select" onchange="window.location.href='@Url.Action("RoleClaims")?roleId=' + this.value">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role" selected="@(role == Model.RoleId)">@role</option>
                    }
                </select>
            </div>
            <div class="col">
                <span class="text-muted">Configure which claims are granted to this role</span>
            </div>
        </div>
    </div>
</div>

<!-- Claims by Category -->
@{
    var categories = Model.ClaimTypes.Select(ct => ct.Category).Distinct().OrderBy(c => c).ToList();
}

@foreach (var category in categories)
{
    var categoryTypes = Model.ClaimTypes.Where(ct => ct.Category == category).ToList();
    
    <div class="card admin-card mb-4">
        <div class="card-header">
            <i class="bi bi-folder me-2"></i>@category
        </div>
        <div class="card-body">
            @foreach (var claimType in categoryTypes.OrderBy(ct => ct.Name))
            {
                <div class="mb-4">
                    <div class="d-flex align-items-center mb-2">
                        @if (!string.IsNullOrEmpty(claimType.Icon))
                        {
                            <i class="bi @claimType.Icon me-2 text-primary"></i>
                        }
                        <h6 class="mb-0">@claimType.Name</h6>
                        <code class="ms-2 small">@claimType.Key</code>
                        @if (!claimType.AllowMultiple)
                        {
                            <span class="badge bg-warning ms-2">Single Value</span>
                        }
                    </div>
                    
                    @if (claimType.Values.Any())
                    {
                        <form asp-action="SaveRoleClaims" method="post" class="ms-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roleId" value="@Model.RoleId" />
                            <input type="hidden" name="claimType" value="@claimType.Key" />
                            
                            <div class="row">
                                @foreach (var value in claimType.Values.OrderBy(v => v.Label))
                                {
                                    var checkboxId = $"claim_{claimType.Key}_{value.Value.Replace(".", "_")}";
                                    <div class="col-md-4 col-lg-3 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" 
                                                   name="claimValues" value="@value.Value"
                                                   id="@checkboxId"
                                                   checked="@value.IsGranted" />
                                            <label class="form-check-label" for="@checkboxId">
                                                @value.Label
                                            </label>
                                            @if (!string.IsNullOrEmpty(value.Description))
                                            {
                                                <small class="d-block text-muted">@value.Description</small>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <div class="mt-2">
                                <button type="submit" class="btn btn-sm btn-primary">
                                    <i class="bi bi-check-lg me-1"></i>Save @claimType.Name Claims
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary ms-1" onclick="toggleAll(this, '@claimType.Key')">
                                    <i class="bi bi-check-all me-1"></i>Toggle All
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <p class="text-muted ms-4 mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            No predefined values. <a asp-action="ClaimTypeDetails" asp-route-id="@claimType.Id">Add values</a>
                        </p>
                    }
                </div>
                
                @if (claimType != categoryTypes.Last())
                {
                    <hr />
                }
            }
        </div>
    </div>
}

@if (!Model.ClaimTypes.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No claim types available. <a asp-action="ClaimTypeCreate">Create claim types</a> first.
    </div>
}

@section Scripts {
    <script>
        function toggleAll(button, claimType) {
            const form = button.closest('form');
            const checkboxes = form.querySelectorAll('input[type="checkbox"]');
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !allChecked);
        }
    </script>
}
