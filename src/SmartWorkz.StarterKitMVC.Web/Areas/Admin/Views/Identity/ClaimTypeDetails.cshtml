@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ClaimTypeViewModel
@{
    ViewData["Title"] = $"Claim Type: {Model.Name}";
}

@section PageActions {
    <a asp-action="ClaimTypeEdit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a asp-action="Claims" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Claims
    </a>
}

<div class="row">
    <div class="col-lg-4">
        <!-- Claim Type Info -->
        <div class="card admin-card mb-4">
            <div class="card-header">
                <i class="bi @(Model.Icon ?? "bi-key") me-2"></i>Claim Type Details
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Key</dt>
                    <dd class="col-sm-8"><code>@Model.Key</code></dd>
                    
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Category</span></dd>
                    
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "—")</dd>
                    
                    <dt class="col-sm-4">Multiple</dt>
                    <dd class="col-sm-8">
                        @if (Model.AllowMultiple)
                        {
                            <i class="bi bi-check-circle text-success"></i> <span>Yes</span>
                        }
                        else
                        {
                            <i class="bi bi-x-circle text-muted"></i> <span>No</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-4">System</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsSystem)
                        {
                            <span class="badge bg-secondary">System</span>
                        }
                        else
                        {
                            <span class="text-muted">Custom</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <!-- Add Value Form -->
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-plus-lg me-2"></i>Add Predefined Value
            </div>
            <div class="card-body">
                <form asp-action="AddClaimValue" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ClaimTypeId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label">Value <span class="text-danger">*</span></label>
                        <input name="Value" class="form-control" required placeholder="e.g., engineering" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Label <span class="text-danger">*</span></label>
                        <input name="Label" class="form-control" required placeholder="e.g., Engineering" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input name="Description" class="form-control" placeholder="Optional description" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Sort Order</label>
                        <input name="SortOrder" type="number" class="form-control" value="@(Model.PredefinedValues.Count + 1)" />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus-lg me-1"></i>Add Value
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <!-- Predefined Values -->
        <div class="card admin-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-list-ul me-2"></i>Predefined Values</span>
                <span class="badge bg-primary">@Model.ValueCount values</span>
            </div>
            <div class="card-body p-0">
                @if (Model.PredefinedValues.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Value</th>
                                    <th>Label</th>
                                    <th>Description</th>
                                    <th class="text-center">Order</th>
                                    <th style="width: 80px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var value in Model.PredefinedValues.OrderBy(v => v.SortOrder))
                                {
                                    <tr>
                                        <td><code>@value.Value</code></td>
                                        <td><strong>@value.Label</strong></td>
                                        <td class="text-muted small">@(value.Description ?? "—")</td>
                                        <td class="text-center">@value.SortOrder</td>
                                        <td>
                                            <form asp-action="RemoveClaimValue" method="post" class="d-inline" onsubmit="return confirm('Remove this value?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="claimTypeId" value="@Model.Id" />
                                                <input type="hidden" name="valueId" value="@value.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No predefined values yet. Add values using the form on the left.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
