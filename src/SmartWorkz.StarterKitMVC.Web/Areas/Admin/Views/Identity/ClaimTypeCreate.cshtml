@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ClaimTypeFormViewModel
@{
    ViewData["Title"] = "Create Claim Type";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-plus-lg me-2"></i>Create New Claim Type
            </div>
            <div class="card-body">
                <form asp-action="ClaimTypeCreate" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
                            <input asp-for="Key" class="form-control" placeholder="e.g., department" />
                            <span asp-validation-for="Key" class="text-danger"></span>
                            <small class="text-muted">Unique identifier (lowercase, no spaces)</small>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Department" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Describe what this claim type represents"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label asp-for="Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <input asp-for="Category" class="form-control" list="categoryList" placeholder="Select or type category" />
                            <datalist id="categoryList">
                                @foreach (var cat in Model.AvailableCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </datalist>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Icon" class="form-label">Icon</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-palette"></i></span>
                                <input asp-for="Icon" class="form-control" placeholder="e.g., bi-key" />
                            </div>
                            <small class="text-muted"><a href="https://icons.getbootstrap.com/" target="_blank">Bootstrap Icons</a></small>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="AllowMultiple" class="form-check-input" type="checkbox" />
                            <label asp-for="AllowMultiple" class="form-check-label">
                                Allow Multiple Values
                            </label>
                            <small class="d-block text-muted">If checked, users/roles can have multiple values for this claim type</small>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Claims" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Create Claim Type
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
