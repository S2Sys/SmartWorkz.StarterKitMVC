@model List<SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.EntityClaimsSummaryViewModel>
@{
    ViewData["Title"] = "Entity Claims";
}

@section PageActions {
    <a asp-action="Claims" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Claims
    </a>
}

<div class="row mb-4">
    <div class="col-12">
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Entity claims provide CRUD (Create, Read, Update, Delete) permissions for each entity/model in your application.
            These are automatically generated based on your domain models.
        </div>
    </div>
</div>

<!-- Generate New Entity Claims -->
<div class="card admin-card mb-4">
    <div class="card-header">
        <i class="bi bi-plus-lg me-2"></i>Generate Entity Claims
    </div>
    <div class="card-body">
        <form asp-action="GenerateEntityClaims" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label">Entity Key <span class="text-danger">*</span></label>
                <input name="entity" class="form-control" required placeholder="e.g., products" />
                <small class="text-muted">Lowercase, no spaces</small>
            </div>
            <div class="col-md-4">
                <label class="form-label">Display Name <span class="text-danger">*</span></label>
                <input name="displayName" class="form-control" required placeholder="e.g., Products" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-gear me-1"></i>Generate Claims
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Entity Claims Grid -->
<div class="row">
    @foreach (var entity in Model.OrderBy(e => e.DisplayName))
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card admin-card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>
                        @if (!string.IsNullOrEmpty(entity.Icon))
                        {
                            <i class="bi @entity.Icon me-2"></i>
                        }
                        else
                        {
                            <i class="bi bi-box me-2"></i>
                        }
                        @entity.DisplayName
                    </span>
                    <code class="small">@entity.Entity</code>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var claim in entity.Claims)
                        {
                            var action = claim.Split('.').LastOrDefault() ?? claim;
                            var badgeClass = action switch
                            {
                                "view" => "bg-info",
                                "create" => "bg-success",
                                "edit" => "bg-warning text-dark",
                                "delete" => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <span class="badge @badgeClass">
                                <i class="bi @(action switch { "view" => "bi-eye", "create" => "bi-plus", "edit" => "bi-pencil", "delete" => "bi-trash", _ => "bi-key" }) me-1"></i>
                                @action
                            </span>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <small class="text-muted">@entity.Claims.Count claims defined</small>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No entity claims defined yet. Use the form above to generate claims for your entities.
    </div>
}

<!-- Quick Reference -->
<div class="card admin-card mt-4">
    <div class="card-header">
        <i class="bi bi-book me-2"></i>Quick Reference: Standard CRUD Claims
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-info me-2"><i class="bi bi-eye"></i></span>
                    <strong>View</strong>
                </div>
                <p class="small text-muted mb-0">Read/list entities</p>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-success me-2"><i class="bi bi-plus"></i></span>
                    <strong>Create</strong>
                </div>
                <p class="small text-muted mb-0">Add new entities</p>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-warning text-dark me-2"><i class="bi bi-pencil"></i></span>
                    <strong>Edit</strong>
                </div>
                <p class="small text-muted mb-0">Modify existing entities</p>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <span class="badge bg-danger me-2"><i class="bi bi-trash"></i></span>
                    <strong>Delete</strong>
                </div>
                <p class="small text-muted mb-0">Remove entities</p>
            </div>
        </div>
    </div>
</div>
