@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.EmailTemplateSectionFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row">
    <!-- Left Column: Form Fields -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-info-circle me-2"></i>Section Information
            </div>
            <div class="card-body">
                <input type="hidden" asp-for="Type">
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Id" class="form-label">Section ID <span class="text-danger">*</span></label>
                        @if (Model.IsEditMode)
                        {
                            <input asp-for="Id" class="form-control" placeholder="e.g., header-default" readonly>
                        }
                        else
                        {
                            <input asp-for="Id" class="form-control" placeholder="e.g., header-default">
                        }
                        <span asp-validation-for="Id" class="text-danger"></span>
                        <div class="form-text">Lowercase letters, numbers, and hyphens only</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label">Section Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Default Header">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsDefault" class="form-check-input" type="checkbox">
                            <label asp-for="IsDefault" class="form-check-label">Set as Default @Model.Type</label>
                        </div>
                        <div class="form-text">Default sections are pre-selected when creating new templates</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox">
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-code-slash me-2"></i>HTML Content</span>
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="previewSection()">
                    <i class="bi bi-eye me-1"></i>Preview
                </button>
            </div>
            <div class="card-body">
                <textarea asp-for="HtmlContent" class="form-control font-monospace" rows="20" 
                          placeholder="<div style='...'>Your HTML content here...</div>"></textarea>
                <span asp-validation-for="HtmlContent" class="text-danger"></span>
                <div class="form-text">
                    Use inline CSS for email compatibility. You can use system placeholders like <code>{{AppName}}</code>, <code>{{CompanyName}}</code>, etc.
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Sidebar -->
    <div class="col-lg-4">
        <!-- Actions Card -->
        <div class="card mb-4 sticky-top" style="top: 1rem;">
            <div class="card-header">
                <i class="bi bi-gear me-2"></i>Actions
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>@(Model.IsEditMode ? "Update Section" : "Create Section")
                    </button>
                    <a asp-action="Sections" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancel
                    </a>
                </div>
            </div>
        </div>

        <!-- System Placeholders Reference -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-bookmark me-2"></i>System Placeholders
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                    @foreach (var ph in Model.SystemPlaceholders)
                    {
                        <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                onclick="insertPlaceholder('@ph.Key')" title="@ph.Description">
                            <div>
                                <code class="text-primary">@ph.Key</code>
                                <br><small class="text-muted">@ph.DisplayName</small>
                            </div>
                            <i class="bi bi-plus-circle text-muted"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="card-footer text-muted small">
                Click to insert into the HTML content
            </div>
        </div>

        <!-- Tips Card -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-lightbulb me-2"></i>Tips
            </div>
            <div class="card-body small">
                <ul class="mb-0 ps-3">
                    <li>Use <strong>inline CSS</strong> for best email client compatibility</li>
                    <li>Avoid external stylesheets or JavaScript</li>
                    <li>Use <strong>table-based layouts</strong> for complex designs</li>
                    <li>Test with multiple email clients</li>
                    <li>Keep images hosted on a public URL</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Preview Modal -->
<div class="modal fade" id="sectionPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-eye me-2"></i>Section Preview
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <iframe id="sectionPreviewFrame" style="width: 100%; height: 400px; border: none;"></iframe>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
