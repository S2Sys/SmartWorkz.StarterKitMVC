@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.EmailTemplateFormViewModel
@{
    ViewData["Title"] = "Create Email Template";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-plus-circle me-2"></i>Create Email Template
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Email Templates</a></li>
                <li class="breadcrumb-item active">Create</li>
            </ol>
        </nav>
    </div>
</div>

<form asp-action="Create" method="post" id="templateForm">
    @await Html.PartialAsync("_TemplateForm", Model)
</form>

@section Scripts {
    @await Html.PartialAsync("_TemplateFormScripts", Model)
}
