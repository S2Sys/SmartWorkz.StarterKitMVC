@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.EmailTemplateSectionFormViewModel
@{
    ViewData["Title"] = $"Create {Model.Type}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-plus-circle me-2"></i>Create @Model.Type
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Email Templates</a></li>
                <li class="breadcrumb-item"><a asp-action="Sections">Sections</a></li>
                <li class="breadcrumb-item active">Create @Model.Type</li>
            </ol>
        </nav>
    </div>
</div>

<form asp-action="CreateSection" method="post">
    @await Html.PartialAsync("_SectionForm", Model)
</form>

@section Scripts {
    @await Html.PartialAsync("_SectionFormScripts", Model)
}
