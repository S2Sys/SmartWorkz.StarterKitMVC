@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.EmailTemplateFormViewModel
@{
    ViewData["Title"] = "Edit Email Template";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-pencil me-2"></i>Edit Email Template
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Email Templates</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
    </div>
    @if (Model.IsSystem)
    {
        <span class="badge bg-info fs-6">
            <i class="bi bi-lock me-1"></i>System Template
        </span>
    }
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="templateForm">
    @await Html.PartialAsync("_TemplateForm", Model)
</form>

@section Scripts {
    @await Html.PartialAsync("_TemplateFormScripts", Model)
}
