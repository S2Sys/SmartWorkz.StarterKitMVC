@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ResourcesIndexViewModel
@{
    ViewData["Title"] = "Localization Resources";
}

@section PageActions {
    <a asp-action="Languages" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-globe me-1"></i>Languages
    </a>
    <a asp-action="Resources" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-translate me-1"></i>Resources
    </a>
    <a asp-action="Export" class="btn btn-outline-info btn-sm">
        <i class="bi bi-download me-1"></i>Export
    </a>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card admin-card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Languages</h6>
                        <h2 class="mb-0">@Model.Languages.Count</h2>
                    </div>
                    <i class="bi bi-globe fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-card bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Resources</h6>
                        <h2 class="mb-0">@Model.TotalResources</h2>
                    </div>
                    <i class="bi bi-translate fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-card bg-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Default Language</h6>
                        <h2 class="mb-0">@(Model.Languages.FirstOrDefault(l => l.IsDefault)?.Code.ToUpperInvariant() ?? "EN")</h2>
                    </div>
                    <i class="bi bi-star fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Translation Progress -->
<div class="card admin-card mb-4">
    <div class="card-header">
        <i class="bi bi-bar-chart me-2"></i>Translation Progress
    </div>
    <div class="card-body">
        <div class="row">
            @foreach (var stat in Model.Stats)
            {
                var lang = Model.Languages.FirstOrDefault(l => l.Code == stat.LanguageCode);
                <div class="col-md-4 mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>
                            @(lang?.Name ?? stat.LanguageCode)
                            @if (lang?.IsDefault == true)
                            {
                                <span class="badge bg-primary ms-1">Default</span>
                            }
                        </span>
                        <span>@stat.TranslatedCount / @stat.TotalResources</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width: @stat.CompletionPercentage%"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-1">
                        <small class="text-muted">@stat.CompletionPercentage.ToString("F1")% complete</small>
                        <a asp-action="Translations" asp-route-languageCode="@stat.LanguageCode" class="small">Edit</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row">
    <div class="col-md-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-globe me-2"></i>Languages
            </div>
            <div class="list-group list-group-flush">
                @foreach (var lang in Model.Languages.Take(5))
                {
                    <a asp-action="Translations" asp-route-languageCode="@lang.Code" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>
                            @lang.Name <small class="text-muted">(@lang.NativeName)</small>
                            @if (lang.IsDefault)
                            {
                                <span class="badge bg-primary ms-1">Default</span>
                            }
                            @if (lang.IsRtl)
                            {
                                <span class="badge bg-secondary ms-1">RTL</span>
                            }
                        </span>
                        <span class="badge bg-secondary">@lang.Code</span>
                    </a>
                }
                <a asp-action="Languages" class="list-group-item list-group-item-action text-primary">
                    <i class="bi bi-arrow-right me-1"></i>Manage all languages
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-translate me-2"></i>Resource Categories
            </div>
            <div class="list-group list-group-flush">
                @{
                    var categories = Model.Resources.Select(r => r.Category).Distinct().Take(5).ToList();
                }
                @foreach (var category in categories)
                {
                    <a asp-action="Resources" asp-route-category="@category" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        @category
                        <span class="badge bg-secondary">@Model.Resources.Count(r => r.Category == category)</span>
                    </a>
                }
                <a asp-action="Resources" class="list-group-item list-group-item-action text-primary">
                    <i class="bi bi-arrow-right me-1"></i>Manage all resources
                </a>
            </div>
        </div>
    </div>
</div>
