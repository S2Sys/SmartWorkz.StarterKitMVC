@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ResourceFormViewModel
@{
    ViewData["Title"] = "Create Resource";
}

@section PageActions {
    <a asp-action="Resources" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Resources
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-plus-lg me-2"></i>Create Resource
            </div>
            <div class="card-body">
                <form asp-action="ResourceCreate" method="post">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
                            <input asp-for="Key" class="form-control" placeholder="e.g., save, cancel, errorRequired" />
                            <span asp-validation-for="Key" class="text-danger"></span>
                            <small class="text-muted">Unique identifier for this resource</small>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <label asp-for="Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select">
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ParentId" class="form-label">Parent Resource</label>
                            <select asp-for="ParentId" class="form-select">
                                <option value="">-- No Parent (Root) --</option>
                                @foreach (var parent in Model.AvailableParents)
                                {
                                    <option value="@parent.Value">@parent.Text</option>
                                }
                            </select>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="Module" class="form-label">Module</label>
                            <input asp-for="Module" class="form-control" placeholder="e.g., Common, Users, Orders" />
                            <span asp-validation-for="Module" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Context for translators"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="MaxLength" class="form-label">Max Length</label>
                            <input asp-for="MaxLength" type="number" class="form-control" placeholder="Optional" />
                            <span asp-validation-for="MaxLength" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-4 mb-3 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="SupportsPluralForms" class="form-check-input" />
                                <label asp-for="SupportsPluralForms" class="form-check-label">Supports Plural Forms</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="PlaceholdersInput" class="form-label">Placeholders</label>
                        <input asp-for="PlaceholdersInput" class="form-control" placeholder="e.g., {0}, {userName}, {count}" />
                        <span asp-validation-for="PlaceholdersInput" class="text-danger"></span>
                        <small class="text-muted">Comma-separated list of placeholders</small>
                    </div>
                    
                    <hr />
                    <h6 class="text-muted mb-3">Default Translation (Optional)</h6>
                    
                    <div class="mb-3">
                        <label asp-for="DefaultValue" class="form-label">Default Language Value</label>
                        <input asp-for="DefaultValue" class="form-control" placeholder="Translation in default language" />
                        <span asp-validation-for="DefaultValue" class="text-danger"></span>
                    </div>
                    
                    @if (Model.SupportsPluralForms)
                    {
                        <div class="mb-3">
                            <label asp-for="PluralValue" class="form-label">Plural Form</label>
                            <input asp-for="PluralValue" class="form-control" placeholder="Plural translation" />
                            <span asp-validation-for="PluralValue" class="text-danger"></span>
                        </div>
                    }
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Create Resource
                        </button>
                        <a asp-action="Resources" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
