@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.LanguageFormViewModel
@{
    ViewData["Title"] = "Add Language";
}

@section PageActions {
    <a asp-action="Languages" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Languages
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-plus-lg me-2"></i>Add Language
            </div>
            <div class="card-body">
                <form asp-action="LanguageCreate" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Code" class="form-label">Code <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" placeholder="e.g., en, en-US" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                            <small class="text-muted">ISO language code</small>
                        </div>
                        
                        <div class="col-md-8 mb-3">
                            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., English" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="NativeName" class="form-label">Native Name <span class="text-danger">*</span></label>
                        <input asp-for="NativeName" class="form-control" placeholder="e.g., English, Español, Français" />
                        <span asp-validation-for="NativeName" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Icon" class="form-label">Icon/Flag</label>
                            <input asp-for="Icon" class="form-control" placeholder="e.g., 🇺🇸 or flag-icon" />
                            <span asp-validation-for="Icon" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input asp-for="IsRtl" class="form-check-input" />
                                <label asp-for="IsRtl" class="form-check-label">Right-to-Left (RTL)</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input asp-for="IsDefault" class="form-check-input" />
                                <label asp-for="IsDefault" class="form-check-label">Set as Default Language</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Add Language
                        </button>
                        <a asp-action="Languages" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
