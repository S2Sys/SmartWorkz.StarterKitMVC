@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ResourceListViewModel
@{
    ViewData["Title"] = "Manage Resources";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <a asp-action="ResourceCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Resource
    </a>
}

<div class="card admin-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Filter by Category</label>
                <select name="category" class="form-select" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(cat == Model.CategoryFilter)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Filter by Module</label>
                <select name="module" class="form-select" onchange="this.form.submit()">
                    <option value="">All Modules</option>
                    @foreach (var mod in Model.Modules)
                    {
                        <option value="@mod" selected="@(mod == Model.ModuleFilter)">@mod</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card admin-card">
    <div class="card-header">
        <i class="bi bi-translate me-2"></i>Resources
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Category</th>
                        <th>Module</th>
                        <th>Translations</th>
                        <th>Type</th>
                        <th style="width: 100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resource in Model.Resources)
                    {
                        @await Html.PartialAsync("_ResourceRow", resource, new ViewDataDictionary(ViewData) { { "Level", 0 }, { "Languages", Model.Languages } })
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete resource <strong id="deleteResourceKey"></strong>?</p>
                <p class="text-danger mb-0"><small>All translations and child resources will also be deleted.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="ResourceDelete" method="post" class="d-inline">
                    <input type="hidden" name="id" id="deleteResourceId">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('deleteModal')?.addEventListener('show.bs.modal', function(e) {
        const button = e.relatedTarget;
        document.getElementById('deleteResourceId').value = button.dataset.id;
        document.getElementById('deleteResourceKey').textContent = button.dataset.key;
    });
</script>
}
