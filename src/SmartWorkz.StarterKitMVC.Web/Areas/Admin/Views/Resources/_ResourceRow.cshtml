@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ResourceViewModel
@{
    var level = (int)(ViewData["Level"] ?? 0);
    var indent = level * 24;
    var languages = ViewData["Languages"] as List<string> ?? new List<string>();
}

<tr>
    <td>
        <div style="padding-left: @(indent)px;">
            <code>@Model.Key</code>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <br /><small class="text-muted" style="padding-left: @(indent)px;">@Model.Description</small>
            }
        </div>
    </td>
    <td><span class="badge bg-secondary">@Model.Category</span></td>
    <td>
        @if (!string.IsNullOrEmpty(Model.Module))
        {
            <span class="badge bg-info">@Model.Module</span>
        }
        else
        {
            <span class="text-muted">-</span>
        }
    </td>
    <td>
        <span class="badge bg-success">@Model.TranslationCount / @languages.Count</span>
    </td>
    <td>
        @if (Model.IsSystem)
        {
            <span class="badge bg-info">System</span>
        }
        else
        {
            <span class="badge bg-primary">Custom</span>
        }
    </td>
    <td>
        <div class="btn-group btn-group-sm">
            <a asp-action="ResourceEdit" asp-route-id="@Model.Id" class="btn btn-outline-secondary" title="Edit">
                <i class="bi bi-pencil"></i>
            </a>
            @if (!Model.IsSystem)
            {
                <button type="button" class="btn btn-outline-danger" title="Delete"
                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                        data-id="@Model.Id" data-key="@Model.Key">
                    <i class="bi bi-trash"></i>
                </button>
            }
        </div>
    </td>
</tr>

@foreach (var child in Model.Children)
{
    @await Html.PartialAsync("_ResourceRow", child, new ViewDataDictionary(ViewData) { { "Level", level + 1 }, { "Languages", languages } })
}
