@model List<SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.LovCategoryListViewModel>
@{
    ViewData["Title"] = "LOV Categories";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-list me-1"></i>View Items
    </a>
    <a asp-action="CategoryCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Category
    </a>
}

<div class="card admin-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Key</th>
                        <th>Items</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>
                                <i class="@category.Icon me-2 text-muted"></i>
                                <span class="fw-medium">@category.Name</span>
                                @if (!string.IsNullOrEmpty(category.Description))
                                {
                                    <br /><small class="text-muted">@category.Description</small>
                                }
                            </td>
                            <td><code>@category.Key</code></td>
                            <td><span class="badge bg-secondary">@category.ItemCount items</span></td>
                            <td>
                                @if (category.IsSystem)
                                {
                                    <span class="badge bg-info">System</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Custom</span>
                                }
                            </td>
                            <td>
                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Index" asp-route-categoryId="@category.Id" class="btn btn-outline-secondary" title="View Items">
                                        <i class="bi bi-list"></i>
                                    </a>
                                    <a asp-action="CategoryEdit" asp-route-id="@category.Id" class="btn btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (!category.IsSystem)
                                    {
                                        <button type="button" class="btn btn-outline-danger" title="Delete"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                data-id="@category.Id" data-name="@category.Name">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete category <strong id="deleteCategoryName"></strong>?</p>
                <p class="text-danger mb-0"><small>All items in this category will also be deleted.</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="CategoryDelete" method="post" class="d-inline">
                    <input type="hidden" name="id" id="deleteCategoryId">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('deleteModal')?.addEventListener('show.bs.modal', function(e) {
        const button = e.relatedTarget;
        document.getElementById('deleteCategoryId').value = button.dataset.id;
        document.getElementById('deleteCategoryName').textContent = button.dataset.name;
    });
</script>
}
