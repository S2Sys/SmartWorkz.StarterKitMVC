@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.LovItemFormViewModel
@{
    ViewData["Title"] = "Edit Item";
}

@section PageActions {
    <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Items
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>Edit Item: @Model.DisplayName
            </div>
            <div class="card-body">
                <form asp-action="ItemEdit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(Model.AvailableCategories, "Id", "Name"))">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
                        <input asp-for="Key" class="form-control" readonly />
                        <span asp-validation-for="Key" class="text-danger"></span>
                        <small class="text-muted">Key cannot be changed after creation</small>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="DisplayName" class="form-label">Display Name <span class="text-danger">*</span></label>
                        <input asp-for="DisplayName" class="form-control" placeholder="e.g., United States" />
                        <span asp-validation-for="DisplayName" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="Color" class="form-label">Color</label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color" id="colorPicker" value="@(Model.Color ?? "#000000")" />
                                <input asp-for="Color" class="form-control" placeholder="#000000" />
                            </div>
                            <span asp-validation-for="Color" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Icon" class="form-label">Icon</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="@(Model.Icon ?? "bi-circle")"></i></span>
                            <input asp-for="Icon" class="form-control" placeholder="e.g., bi-flag" />
                        </div>
                        <span asp-validation-for="Icon" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check form-switch">
                                <input asp-for="IsDefault" class="form-check-input" />
                                <label asp-for="IsDefault" class="form-check-label">Default</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('colorPicker')?.addEventListener('input', function() {
        document.getElementById('Color').value = this.value;
    });
</script>
}
