@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.LovCategoryFormViewModel
@{
    ViewData["Title"] = "Create Category";
}

@section PageActions {
    <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Categories
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-folder-plus me-2"></i>Create LOV Category
            </div>
            <div class="card-body">
                <form asp-action="CategoryCreate" method="post">
                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
                        <input asp-for="Key" class="form-control" placeholder="e.g., countries" />
                        <span asp-validation-for="Key" class="text-danger"></span>
                        <small class="text-muted">Unique identifier (lowercase, underscores only)</small>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Countries" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Brief description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Icon" class="form-label">Icon</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="@(Model.Icon ?? "bi-folder")"></i></span>
                            <input asp-for="Icon" class="form-control" placeholder="e.g., bi-globe" />
                        </div>
                        <span asp-validation-for="Icon" class="text-danger"></span>
                        <small class="text-muted">Bootstrap Icons class name</small>
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Create Category
                        </button>
                        <a asp-action="Categories" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
