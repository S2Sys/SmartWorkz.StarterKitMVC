@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.ConfigSectionViewModel

@if (Model.Children.Any())
{
    <div class="row">
        @foreach (var child in Model.Children)
        {
            @if (child.IsObject && child.Children.Any())
            {
                <div class="col-12 mb-3">
                    <div class="card border-secondary">
                        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center"
                             data-bs-toggle="collapse" data-bs-target="#collapse-@child.Path.Replace(":", "-")"
                             style="cursor: pointer;">
                            <span>
                                <i class="@child.Icon me-2 text-secondary"></i>
                                <strong>@child.Key</strong>
                            </span>
                            <div>
                                <span class="badge bg-secondary me-2">@child.Children.Count settings</span>
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>
                        <div class="collapse show" id="collapse-@child.Path.Replace(":", "-")">
                            <div class="card-body">
                                @await Html.PartialAsync("_ConfigSection", child)
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (child.IsArray)
            {
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="bi bi-list-ul me-1 text-muted"></i>@child.Key
                        <span class="badge bg-info ms-1">Array</span>
                    </label>
                    <textarea class="form-control font-monospace" rows="3"
                              data-config-path="@child.Path"
                              data-config-type="array">@child.JsonValue</textarea>
                    <small class="text-muted">JSON array format</small>
                </div>
            }
            else if (child.IsObject)
            {
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="bi bi-braces me-1 text-muted"></i>@child.Key
                        <span class="badge bg-secondary ms-1">Object</span>
                    </label>
                    <textarea class="form-control font-monospace" rows="3"
                              data-config-path="@child.Path"
                              data-config-type="object">@child.JsonValue</textarea>
                    <small class="text-muted">JSON object format</small>
                </div>
            }
            else
            {
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        @if (child.ValueType == "boolean")
                        {
                            <i class="bi bi-toggle-on me-1 text-muted"></i>
                        }
                        else if (child.ValueType == "number")
                        {
                            <i class="bi bi-123 me-1 text-muted"></i>
                        }
                        else
                        {
                            <i class="bi bi-type me-1 text-muted"></i>
                        }
                        @child.Key
                    </label>
                    
                    @if (child.ValueType == "boolean")
                    {
                        <div class="form-check form-switch">
                            <input type="checkbox" class="form-check-input config-input"
                                   data-config-path="@child.Path"
                                   data-config-type="boolean"
                                   id="config-@child.Path.Replace(":", "-")"
                                   @(child.Value?.ToLower() == "true" ? "checked" : "")>
                            <label class="form-check-label" for="config-@child.Path.Replace(":", "-")">
                                @(child.Value?.ToLower() == "true" ? "Enabled" : "Disabled")
                            </label>
                        </div>
                    }
                    else if (child.ValueType == "number")
                    {
                        <input type="number" class="form-control config-input"
                               data-config-path="@child.Path"
                               data-config-type="number"
                               value="@child.Value">
                    }
                    else if (child.Key.ToLower().Contains("password") || 
                             child.Key.ToLower().Contains("secret") || 
                             child.Key.ToLower().Contains("apikey") ||
                             child.Key.ToLower().Contains("authtoken"))
                    {
                        <div class="input-group">
                            <input type="password" class="form-control config-input"
                                   data-config-path="@child.Path"
                                   data-config-type="string"
                                   value="@child.Value"
                                   id="input-@child.Path.Replace(":", "-")">
                            <button type="button" class="btn btn-outline-secondary toggle-password" 
                                    data-target="input-@child.Path.Replace(":", "-")">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <small class="text-muted"><i class="bi bi-lock me-1"></i>Sensitive value</small>
                    }
                    else if (child.Key.ToLower().Contains("connectionstring"))
                    {
                        <textarea class="form-control font-monospace config-input" rows="2"
                                  data-config-path="@child.Path"
                                  data-config-type="string">@child.Value</textarea>
                    }
                    else if (child.Key == "FormDisplayMode")
                    {
                        var isOffcanvas = child.Value == "offcanvas";
                        var isModal = child.Value == "modal";
                        <select class="form-select config-input"
                                data-config-path="@child.Path"
                                data-config-type="string">
                            @if (isOffcanvas)
                            {
                                <option value="offcanvas" selected>Offcanvas (Right Sidebar)</option>
                            }
                            else
                            {
                                <option value="offcanvas">Offcanvas (Right Sidebar)</option>
                            }
                            @if (isModal)
                            {
                                <option value="modal" selected>Modal Dialog</option>
                            }
                            else
                            {
                                <option value="modal">Modal Dialog</option>
                            }
                        </select>
                        <small class="text-muted">How edit forms are displayed in admin</small>
                    }
                    else
                    {
                        <input type="text" class="form-control config-input"
                               data-config-path="@child.Path"
                               data-config-type="string"
                               value="@child.Value">
                    }
                </div>
            }
        }
    </div>
}
