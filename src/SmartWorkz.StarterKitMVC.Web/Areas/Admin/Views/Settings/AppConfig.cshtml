@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.AppConfigViewModel
@{
    ViewData["Title"] = "Application Configuration";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-file-earmark-code me-2"></i>Application Configuration
        </h1>
        <p class="text-muted mb-0">Edit appsettings.json configuration file</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Settings
        </a>
    </div>
</div>

<div class="alert alert-warning d-flex align-items-center mb-4">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <div>
        <strong>Caution:</strong> Changes to this file may require an application restart. 
        A backup is created automatically before saving.
    </div>
</div>

<div class="row">
    <!-- Sections Navigation -->
    <div class="col-lg-3 mb-4">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-list-nested me-2"></i>Configuration Sections
            </div>
            <div class="list-group list-group-flush" style="max-height: 600px; overflow-y: auto;">
                @foreach (var cfg in Model.Sections)
                {
                    <a href="#section-@cfg.Key" class="list-group-item list-group-item-action d-flex align-items-center">
                        <i class="@cfg.Icon me-2 text-primary"></i>
                        <span>@cfg.Key</span>
                        @if (cfg.IsObject)
                        {
                            <span class="badge bg-secondary ms-auto">@cfg.Children.Count</span>
                        }
                    </a>
                }
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <i class="bi bi-info-circle me-2"></i>Quick Links
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="EmailTemplates" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-envelope-paper me-2 text-primary"></i>Email Templates
                </a>
                <a asp-controller="Notifications" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-bell me-2 text-primary"></i>Notifications
                </a>
                <a asp-controller="Identity" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-people me-2 text-primary"></i>Identity Settings
                </a>
            </div>
        </div>
    </div>

    <!-- Configuration Editor -->
    <div class="col-lg-9">
        <!-- Tabs -->
        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#visual-editor" type="button">
                    <i class="bi bi-ui-checks me-1"></i>Visual Editor
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#json-editor" type="button">
                    <i class="bi bi-code-slash me-1"></i>JSON Editor
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- Visual Editor Tab -->
            <div class="tab-pane fade show active" id="visual-editor">
                @foreach (var cfg in Model.Sections)
                {
                    <div class="card mb-3" id="section-@cfg.Key">
                        <div class="card-header d-flex justify-content-between align-items-center" 
                             data-bs-toggle="collapse" data-bs-target="#collapse-@cfg.Key" 
                             style="cursor: pointer;">
                            <span>
                                <i class="@cfg.Icon me-2"></i>@cfg.Key
                            </span>
                            <i class="bi bi-chevron-down"></i>
                        </div>
                        <div class="collapse show" id="collapse-@cfg.Key">
                            <div class="card-body">
                                @if (cfg.IsObject && cfg.Children.Any())
                                {
                                    @await Html.PartialAsync("_ConfigSection", cfg)
                                }
                                else if (cfg.IsArray)
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">@cfg.Key</label>
                                        <textarea class="form-control font-monospace" rows="4" 
                                                  data-cfg-path="@cfg.Path"
                                                  data-cfg-type="array">@cfg.JsonValue</textarea>
                                    </div>
                                }
                                else
                                {
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">@cfg.Key</label>
                                            @if (cfg.ValueType == "boolean")
                                            {
                                                <div class="form-check form-switch">
                                                    <input type="checkbox" class="form-check-input" 
                                                           data-config-path="@cfg.Path"
                                                           @(cfg.Value?.ToLower() == "true" ? "checked" : "")>
                                                </div>
                                            }
                                            else
                                            {
                                                <input type="text" class="form-control" 
                                                       data-config-path="@cfg.Path"
                                                       value="@cfg.Value">
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- JSON Editor Tab -->
            <div class="tab-pane fade" id="json-editor">
                <form asp-action="SaveAppConfig" method="post">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-braces me-2"></i>appsettings.json</span>
                            <div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="formatJson">
                                    <i class="bi bi-text-indent-left me-1"></i>Format
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="validateJson">
                                    <i class="bi bi-check-circle me-1"></i>Validate
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <textarea name="RawJson" id="jsonEditor" class="form-control font-monospace border-0" 
                                      rows="30" style="resize: vertical; border-radius: 0;">@Model.RawJson</textarea>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Save Configuration
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="reloadJson">
                                <i class="bi bi-arrow-clockwise me-1"></i>Reload
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Format JSON button
        document.getElementById('formatJson')?.addEventListener('click', function() {
            const editor = document.getElementById('jsonEditor');
            try {
                const json = JSON.parse(editor.value);
                editor.value = JSON.stringify(json, null, 2);
                SW.toast.success('JSON formatted successfully');
            } catch (e) {
                SW.toast.error('Invalid JSON: ' + e.message);
            }
        });

        // Validate JSON button
        document.getElementById('validateJson')?.addEventListener('click', function() {
            const editor = document.getElementById('jsonEditor');
            try {
                JSON.parse(editor.value);
                SW.toast.success('JSON is valid');
            } catch (e) {
                SW.toast.error('Invalid JSON: ' + e.message);
            }
        });

        // Reload button
        document.getElementById('reloadJson')?.addEventListener('click', function() {
            location.reload();
        });

        // Smooth scroll to sections
        document.querySelectorAll('a[href^="#section-"]').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    });
</script>
}
