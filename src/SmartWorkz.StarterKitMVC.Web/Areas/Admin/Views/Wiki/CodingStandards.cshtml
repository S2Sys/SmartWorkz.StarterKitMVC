@{
    ViewData["Title"] = "Coding Standards";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">
            <i class="bi bi-code-square me-2"></i>Coding Standards
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Wiki</a></li>
                <li class="breadcrumb-item active">Coding Standards</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-lg-9">
        <!-- C# Coding Standards -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-filetype-cs me-2"></i>C# Coding Standards
            </div>
            <div class="card-body">
                <h5 class="text-primary">Naming Conventions</h5>
                <table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Element</th>
                            <th>Convention</th>
                            <th>Example</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Classes, Records, Structs</td>
                            <td><code>PascalCase</code></td>
                            <td><code>EmailTemplateService</code></td>
                        </tr>
                        <tr>
                            <td>Interfaces</td>
                            <td><code>IPascalCase</code></td>
                            <td><code>IEmailTemplateRepository</code></td>
                        </tr>
                        <tr>
                            <td>Methods</td>
                            <td><code>PascalCase</code></td>
                            <td><code>GetTemplateByIdAsync</code></td>
                        </tr>
                        <tr>
                            <td>Properties</td>
                            <td><code>PascalCase</code></td>
                            <td><code>IsActive</code></td>
                        </tr>
                        <tr>
                            <td>Private Fields</td>
                            <td><code>_camelCase</code></td>
                            <td><code>_templateService</code></td>
                        </tr>
                        <tr>
                            <td>Local Variables</td>
                            <td><code>camelCase</code></td>
                            <td><code>templateId</code></td>
                        </tr>
                        <tr>
                            <td>Parameters</td>
                            <td><code>camelCase</code></td>
                            <td><code>cancellationToken</code></td>
                        </tr>
                        <tr>
                            <td>Constants</td>
                            <td><code>PascalCase</code></td>
                            <td><code>MaxRetryCount</code></td>
                        </tr>
                        <tr>
                            <td>Enums</td>
                            <td><code>PascalCase</code></td>
                            <td><code>PlaceholderType.Text</code></td>
                        </tr>
                        <tr>
                            <td>Async Methods</td>
                            <td><code>PascalCaseAsync</code></td>
                            <td><code>SaveTemplateAsync</code></td>
                        </tr>
                    </tbody>
                </table>

                <h5 class="text-primary mt-4">Do's ✅</h5>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>var</code> when the type is obvious</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>var templates = await _repository.GetAllTemplatesAsync();
var count = templates.Count;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use expression-bodied members for simple methods</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public string GetFullName() => $"{FirstName} {LastName}";</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>sealed</code> for classes not designed for inheritance</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public sealed class EmailTemplateService : IEmailTemplateService</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>record</code> for immutable data transfer objects</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public sealed record EmailTemplateRenderResult(
    string Subject,
    string HtmlBody,
    string? PlainTextBody,
    bool Success,
    IReadOnlyList&lt;string&gt; Errors
);</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use nullable reference types</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public string? Description { get; set; }
public async Task&lt;EmailTemplate?&gt; GetTemplateByIdAsync(string id)</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>CancellationToken</code> for async operations</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public async Task&lt;IReadOnlyList&lt;EmailTemplate&gt;&gt; GetAllTemplatesAsync(
    CancellationToken cancellationToken = default)</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use pattern matching</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>if (result is { Success: true, HtmlBody: not null })
{
    // Process result
}</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use collection expressions (.NET 9)</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>List&lt;string&gt; errors = [];
string[] tags = ["email", "notification"];</code></pre>
                    </li>
                </ul>

                <h5 class="text-primary mt-4">Don'ts ❌</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use Hungarian notation</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>// ❌ Bad
string strName;
int iCount;

// ✅ Good
string name;
int count;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use abbreviations (except well-known ones)</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>// ❌ Bad
var tmplt = GetTemplate();
var cfg = GetConfig();

// ✅ Good
var template = GetTemplate();
var config = GetConfig();
var id = GetId(); // OK - well-known</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't catch generic exceptions without logging</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>// ❌ Bad
try { ... }
catch (Exception) { }

// ✅ Good
try { ... }
catch (Exception ex)
{
    _logger.LogError(ex, "Failed to process template {Id}", templateId);
    throw;
}</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use magic numbers/strings</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>// ❌ Bad
if (retryCount > 3) { ... }

// ✅ Good
private const int MaxRetryCount = 3;
if (retryCount > MaxRetryCount) { ... }</code></pre>
                    </li>
                </ul>
            </div>
        </div>

        <!-- ASP.NET Core MVC Standards -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-window me-2"></i>ASP.NET Core MVC Standards
            </div>
            <div class="card-body">
                <h5 class="text-primary">Controller Standards</h5>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>[Area]</code> attribute for admin controllers</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>[Area("Admin")]
public class EmailTemplatesController : Controller</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use constructor injection for dependencies</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public class EmailTemplatesController : Controller
{
    private readonly IEmailTemplateService _templateService;
    
    public EmailTemplatesController(IEmailTemplateService templateService)
    {
        _templateService = templateService;
    }
}</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>TempData</code> for redirect messages</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>TempData["Success"] = "Template saved successfully.";
return RedirectToAction(nameof(Index));</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>nameof()</code> for action names</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>return RedirectToAction(nameof(Edit), new { id = template.Id });</code></pre>
                    </li>
                </ul>

                <h5 class="text-primary mt-4">View Standards</h5>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use strongly-typed views with <code>@@model</code></strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>@@model EmailTemplateFormViewModel</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use Tag Helpers over HTML Helpers</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;!-- ✅ Good --&gt;
&lt;input asp-for="Name" class="form-control" /&gt;

&lt;!-- ❌ Avoid --&gt;
@@Html.TextBoxFor(m => m.Name, new { @@class = "form-control" })</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use partial views for reusable components</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>@@await Html.PartialAsync("_TemplateForm", Model)</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use sections for page-specific scripts</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>@@section Scripts {
    &lt;script&gt;
        // Page-specific JavaScript
    &lt;/script&gt;
}</code></pre>
                    </li>
                </ul>

                <h5 class="text-primary mt-4">ViewModel Standards</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use Data Annotations for validation</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public class EmailTemplateFormViewModel
{
    [Required(ErrorMessage = "Template ID is required")]
    [RegularExpression("^[a-z0-9\\-]+$", ErrorMessage = "Only lowercase letters, numbers, and hyphens")]
    [StringLength(100)]
    public string Id { get; set; } = string.Empty;
    
    [Required]
    [StringLength(200)]
    public string Name { get; set; } = string.Empty;
}</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Suffix ViewModels appropriately</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>EmailTemplateListViewModel    // For list views
EmailTemplateFormViewModel    // For create/edit forms
EmailTemplateItemViewModel    // For individual items in lists</code></pre>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Bootstrap & CSS Standards -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-bootstrap me-2"></i>Bootstrap 5 & CSS Standards
            </div>
            <div class="card-body">
                <h5 class="text-primary">Do's ✅</h5>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use Bootstrap utility classes</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;div class="d-flex justify-content-between align-items-center mb-4"&gt;
&lt;span class="text-muted small"&gt;Updated: ...&lt;/span&gt;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use Bootstrap Icons consistently</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;i class="bi bi-envelope-paper me-2"&gt;&lt;/i&gt;Email Templates
&lt;i class="bi bi-plus-lg me-1"&gt;&lt;/i&gt;Create</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use CSS custom properties for theming</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>:root {
    --admin-primary: #3c8dbc;
    --admin-sidebar-width: 280px;
}

.sidebar { width: var(--admin-sidebar-width); }</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Support dark mode with <code>[data-bs-theme="dark"]</code></strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>[data-bs-theme="dark"] .admin-card {
    background: #212529;
}</code></pre>
                    </li>
                </ul>

                <h5 class="text-primary mt-4">Don'ts ❌</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use inline styles</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;!-- ❌ Bad --&gt;
&lt;div style="margin-bottom: 20px; color: red;"&gt;

&lt;!-- ✅ Good --&gt;
&lt;div class="mb-4 text-danger"&gt;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use <code>!important</code> unless absolutely necessary</strong>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't mix Bootstrap 4 and 5 classes</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;!-- ❌ Bad (BS4) --&gt;
&lt;div class="ml-3 mr-3"&gt;

&lt;!-- ✅ Good (BS5) --&gt;
&lt;div class="ms-3 me-3"&gt;</code></pre>
                    </li>
                </ul>
            </div>
        </div>

        <!-- JavaScript Standards -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-filetype-js me-2"></i>JavaScript Standards
            </div>
            <div class="card-body">
                <h5 class="text-primary">Do's ✅</h5>
                <ul class="list-group list-group-flush mb-3">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use <code>const</code> and <code>let</code>, never <code>var</code></strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>const templateId = 'welcome-email';
let count = 0;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use async/await for asynchronous operations</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>async function previewTemplate() {
    SW.loading.show();
    try {
        const response = await fetch('/api/preview', { method: 'POST' });
        const result = await response.json();
        // Handle result
    } catch (error) {
        SW.toast.error('Preview failed: ' + error.message);
    } finally {
        SW.loading.hide();
    }
}</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use the SW namespace for global utilities</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>SW.loading.show('Loading...');
SW.loading.hide();
SW.toast.success('Saved!');
SW.toast.error('Failed!');
await SW.confirm.show({ title: 'Delete?', message: '...' });</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use template literals for string interpolation</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>const message = `Template "${name}" saved successfully.`;</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use arrow functions for callbacks</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>document.querySelectorAll('.btn').forEach(btn => {
    btn.addEventListener('click', () => handleClick());
});</code></pre>
                    </li>
                </ul>

                <h5 class="text-primary mt-4">Don'ts ❌</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use jQuery (use vanilla JS)</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>// ❌ Bad
$('#myElement').hide();

// ✅ Good
document.getElementById('myElement').style.display = 'none';</code></pre>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-x-circle text-danger me-2"></i>
                        <strong>Don't use inline event handlers</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>&lt;!-- ❌ Bad --&gt;
&lt;button onclick="handleClick()"&gt;

&lt;!-- ✅ Good --&gt;
&lt;button id="myBtn"&gt;
&lt;script&gt;
document.getElementById('myBtn').addEventListener('click', handleClick);
&lt;/script&gt;</code></pre>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Clean Architecture Standards -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-layers me-2"></i>Clean Architecture Standards
            </div>
            <div class="card-body">
                <h5 class="text-primary">Layer Responsibilities</h5>
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Layer</th>
                            <th>Contains</th>
                            <th>Dependencies</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Domain</strong></td>
                            <td>Entities, Value Objects, Enums, Domain Events</td>
                            <td>Shared only</td>
                        </tr>
                        <tr>
                            <td><strong>Application</strong></td>
                            <td>Interfaces, DTOs, Service Contracts, Use Cases</td>
                            <td>Domain, Shared</td>
                        </tr>
                        <tr>
                            <td><strong>Infrastructure</strong></td>
                            <td>Implementations, Data Access, External Services</td>
                            <td>Application, Domain, Shared</td>
                        </tr>
                        <tr>
                            <td><strong>Web</strong></td>
                            <td>Controllers, Views, ViewModels, Middleware</td>
                            <td>Application, Infrastructure, Shared</td>
                        </tr>
                        <tr>
                            <td><strong>Shared</strong></td>
                            <td>Extensions, Utilities, Primitives</td>
                            <td>None</td>
                        </tr>
                    </tbody>
                </table>

                <h5 class="text-primary mt-4">Do's ✅</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Define interfaces in Application layer, implement in Infrastructure</strong>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Keep Domain layer free of external dependencies</strong>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Use dependency injection for all services</strong>
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Create extension methods for DI registration</strong>
                        <pre class="bg-light p-2 mt-2 rounded"><code>public static IServiceCollection AddEmailTemplates(
    this IServiceCollection services, 
    string? storagePath = null)
{
    services.AddSingleton&lt;IEmailTemplateRepository&gt;(sp => 
        new JsonEmailTemplateRepository(storagePath));
    services.AddScoped&lt;IEmailTemplateService, EmailTemplateService&gt;();
    return services;
}</code></pre>
                    </li>
                </ul>
            </div>
        </div>
    </div>

