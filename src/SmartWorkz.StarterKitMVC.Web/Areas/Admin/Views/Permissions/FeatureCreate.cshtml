@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.FeatureFormViewModel
@{
    ViewData["Title"] = "Create Feature";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Features
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-plus-lg me-2"></i>Create Feature
            </div>
            <div class="card-body">
                <form asp-action="FeatureCreate" method="post">
                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">Key <span class="text-danger">*</span></label>
                        <input asp-for="Key" class="form-control" placeholder="e.g., orders" />
                        <span asp-validation-for="Key" class="text-danger"></span>
                        <small class="text-muted">Unique identifier (lowercase, underscores only)</small>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Orders" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Brief description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Icon" class="form-label">Icon</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-grid"></i></span>
                                <input asp-for="Icon" class="form-control" placeholder="e.g., bi-cart" />
                            </div>
                            <span asp-validation-for="Icon" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ParentId" class="form-label">Parent Feature</label>
                        <select asp-for="ParentId" class="form-select">
                            <option value="">-- No Parent (Root) --</option>
                            @foreach (var parent in Model.AvailableParents)
                            {
                                <option value="@parent.Value">@parent.Text</option>
                            }
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="GenerateStandardPermissions" class="form-check-input" />
                            <label asp-for="GenerateStandardPermissions" class="form-check-label">
                                Generate standard CRUD permissions (View, Create, Edit, Delete)
                            </label>
                        </div>
                    </div>
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Create Feature
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
