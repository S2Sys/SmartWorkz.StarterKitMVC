@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.FeatureFormViewModel
@{
    ViewData["Title"] = $"Edit Feature: {Model.Name}";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Features
    </a>
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-pencil me-2"></i>Edit Feature: @Model.Name
            </div>
            <div class="card-body">
                <form asp-action="FeatureEdit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">Key</label>
                        <input asp-for="Key" class="form-control" readonly />
                        <small class="text-muted">Key cannot be changed after creation</small>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Icon" class="form-label">Icon</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="@(Model.Icon ?? "bi-grid")"></i></span>
                                <input asp-for="Icon" class="form-control" />
                            </div>
                            <span asp-validation-for="Icon" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ParentId" class="form-label">Parent Feature</label>
                        <select asp-for="ParentId" class="form-select">
                            <option value="">-- No Parent (Root) --</option>
                            @foreach (var parent in Model.AvailableParents)
                            {
                                <option value="@parent.Value">@parent.Text</option>
                            }
                        </select>
                    </div>
                    
                    @if (Model.IsSystem)
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>This is a system feature and has limited editing capabilities.
                        </div>
                    }
                    
                    <div class="pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
