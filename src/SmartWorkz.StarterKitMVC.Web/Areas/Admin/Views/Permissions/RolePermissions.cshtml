@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.RolePermissionsViewModel
@{
    ViewData["Title"] = $"Permissions for Role: {Model.RoleId}";
}

@section PageActions {
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Features
    </a>
}

<div class="row">
    <div class="col-lg-3 mb-4">
        <div class="card admin-card">
            <div class="card-header">
                <i class="bi bi-shield me-2"></i>Select Role
            </div>
            <div class="list-group list-group-flush">
                @foreach (var role in Model.AvailableRoles)
                {
                    <a asp-action="RolePermissions" asp-route-roleId="@role" 
                       class="list-group-item list-group-item-action @(role == Model.RoleId ? "active" : "")">
                        <i class="bi bi-person-badge me-2"></i>@role
                    </a>
                }
            </div>
        </div>
    </div>
    
    <div class="col-lg-9">
        <form asp-action="SaveRolePermissions" method="post">
            <input type="hidden" name="roleId" value="@Model.RoleId" />
            
            <div class="card admin-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-key me-2"></i>Permissions for: <strong>@Model.RoleId</strong></span>
                    <div>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="selectAll">Select All</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAll">Deselect All</button>
                    </div>
                </div>
                <div class="card-body">
                    @foreach (var feature in Model.Features)
                    {
                        @await Html.PartialAsync("_FeaturePermissions", feature, new ViewDataDictionary(ViewData) { { "Level", 0 } })
                    }
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Save Permissions
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('selectAll')?.addEventListener('click', function() {
        document.querySelectorAll('input[name="permissionIds"]').forEach(cb => cb.checked = true);
    });
    
    document.getElementById('deselectAll')?.addEventListener('click', function() {
        document.querySelectorAll('input[name="permissionIds"]').forEach(cb => cb.checked = false);
    });
    
    // Select/deselect all permissions for a feature
    document.querySelectorAll('.feature-toggle').forEach(toggle => {
        toggle.addEventListener('click', function() {
            const featureId = this.dataset.featureId;
            const checkboxes = document.querySelectorAll(`input[data-feature="${featureId}"]`);
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !allChecked);
        });
    });
</script>
}
