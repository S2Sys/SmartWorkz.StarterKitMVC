@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.PermissionsIndexViewModel
@{
    ViewData["Title"] = "Permissions & Features";
}

@section PageActions {
    <a asp-action="FeatureCreate" class="btn btn-primary btn-sm me-2">
        <i class="bi bi-plus-lg me-1"></i>Add Feature
    </a>
    <a asp-action="Permissions" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-key me-1"></i>All Permissions
    </a>
    <a asp-action="RolePermissions" class="btn btn-outline-info btn-sm">
        <i class="bi bi-shield-check me-1"></i>Role Permissions
    </a>
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card admin-card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Features</h6>
                        <h2 class="mb-0">@Model.TotalFeatures</h2>
                    </div>
                    <i class="bi bi-grid-3x3-gap fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card admin-card bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Permissions</h6>
                        <h2 class="mb-0">@Model.TotalPermissions</h2>
                    </div>
                    <i class="bi bi-key fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card admin-card">
    <div class="card-header">
        <i class="bi bi-grid-3x3-gap me-2"></i>Features & Permissions
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th>Key</th>
                        <th>Permissions</th>
                        <th>Type</th>
                        <th style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var feature in Model.Features)
                    {
                        @await Html.PartialAsync("_FeatureRow", feature, new ViewDataDictionary(ViewData) { { "Level", 0 } })
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
