@model SmartWorkz.StarterKitMVC.Web.Areas.Admin.Models.FeatureViewModel
@{
    var level = (int)(ViewData["Level"] ?? 0);
    var indent = level * 24;
}

<tr>
    <td>
        <div style="padding-left: @(indent)px;">
            <i class="@(Model.Icon ?? "bi-folder") me-2 text-muted"></i>
            <span class="fw-medium">@Model.Name</span>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <br /><small class="text-muted" style="padding-left: @(indent + 24)px;">@Model.Description</small>
            }
        </div>
    </td>
    <td><code>@Model.Key</code></td>
    <td><span class="badge bg-secondary">@Model.PermissionCount permissions</span></td>
    <td>
        @if (Model.IsSystem)
        {
            <span class="badge bg-info">System</span>
        }
        else
        {
            <span class="badge bg-primary">Custom</span>
        }
    </td>
    <td>
        <div class="btn-group btn-group-sm">
            <a asp-action="Permissions" asp-route-entity="@Model.Key" class="btn btn-outline-secondary" title="View Permissions">
                <i class="bi bi-key"></i>
            </a>
            <a asp-action="FeatureEdit" asp-route-id="@Model.Id" class="btn btn-outline-secondary" title="Edit">
                <i class="bi bi-pencil"></i>
            </a>
            @if (!Model.IsSystem)
            {
                <button type="button" class="btn btn-outline-danger" title="Delete"
                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                        data-id="@Model.Id" data-name="@Model.Name">
                    <i class="bi bi-trash"></i>
                </button>
            }
        </div>
    </td>
</tr>

@foreach (var child in Model.Children)
{
    @await Html.PartialAsync("_FeatureRow", child, new ViewDataDictionary(ViewData) { { "Level", level + 1 } })
}
