<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartWorkz.ECommerce.Mobile.Pages.OrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:SmartWorkz.ECommerce.Mobile.Converters"
    Title="My Orders"
    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#212121}">

    <ContentPage.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">

        <!-- Error Message -->
        <Label
            Grid.Row="0"
            Text="{Binding ErrorMessage}"
            TextColor="Red"
            IsVisible="{Binding IsError}"
            Padding="16,8"
            FontSize="12" />

        <!-- Loading Indicator -->
        <ActivityIndicator
            Grid.Row="0"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Primary}"
            Margin="0,8" />

        <!-- Orders List -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsBusy}">

            <CollectionView
                ItemsSource="{Binding Orders}"
                EmptyView="No orders yet. Start shopping!"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="8">
                            <Frame
                                CornerRadius="12"
                                Padding="16"
                                BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                                HasShadow="True"
                                Margin="8,4">

                                <Grid
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto,Auto,Auto"
                                    ColumnSpacing="12"
                                    RowSpacing="8">

                                    <!-- Order ID and Date -->
                                    <StackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                        <Label
                                            Text="{Binding Id, StringFormat='Order #{0}'}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                                        <Label
                                            Text="{Binding PlacedAt, StringFormat='Placed: {0:MMM dd, yyyy}'}"
                                            FontSize="12"
                                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                                    </StackLayout>

                                    <!-- Status Badge -->
                                    <Frame
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        CornerRadius="6"
                                        Padding="12,6"
                                        BorderColor="Transparent"
                                        BackgroundColor="{Binding Status, Converter={StaticResource StatusToColor}}">
                                        <Label
                                            Text="{Binding Status}"
                                            TextColor="White"
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Frame>

                                    <!-- Items Count -->
                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Text="{Binding Items, StringFormat='Items: {0}'}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                                    <!-- Total Price -->
                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding Total, StringFormat='{0:C}'}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource Primary}"
                                        HorizontalTextAlignment="End" />

                                    <!-- View Details Link (optional) -->
                                    <Label
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Text="Tap to view details"
                                        FontSize="11"
                                        TextColor="{StaticResource Primary}"
                                        FontAttributes="Italic"
                                        Margin="0,4,0,0" />

                                </Grid>
                            </Frame>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
